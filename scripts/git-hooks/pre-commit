#!/bin/sh
# Yagu pre-commit hook: enforce the "latest installer per architecture in LFS" policy.
#
# Policy:
#   * Yagu ships one installer per CPU architecture: installer/YaguSetup-<version>-<arch>.exe
#     where <arch> is x64, x86, or arm64, plus the OFFLINE x64 edition (OCR bundled)
#     installer/YaguSetup-<version>-x64-offline.exe.
#   * At most ONE installer per architecture/edition may be tracked in git at a time, and it
#     must be the highest version (the latest build) for that architecture/edition.
#   * Each tracked installer must be a Git LFS pointer, never a raw 100MB+ blob.
#
# Behaviour:
#   * Older installer EXEs for an architecture are removed from the index (files stay on disk).
#   * Legacy/unknown installers (e.g. the old YaguSetup-<version>.exe with no arch suffix)
#     are removed from the index as well.
#   * A staged installer that is a raw binary instead of an LFS pointer
#     aborts the commit with instructions.
#
# This hook is version-controlled at scripts/git-hooks/pre-commit and installed
# into .git/hooks/pre-commit by scripts/install-git-hooks.ps1 (so it coexists
# with the Git LFS hooks instead of replacing them via core.hooksPath).

set -e

pattern='installer/YaguSetup-*.exe'

# All installer EXEs currently in the index (staged additions + already committed).
exes=$(git ls-files -- "$pattern")
[ -z "$exes" ] && exit 0

# Highest-version installer to keep for each known architecture/edition.
# Note: -x64.exe intentionally excludes the -x64-offline.exe edition (its own keep slot below).
keep_x64=$(printf '%s\n' "$exes" | grep -E '\-x64\.exe$' | sort -V | tail -n 1 || true)
keep_x86=$(printf '%s\n' "$exes" | grep -E '\-x86\.exe$' | sort -V | tail -n 1 || true)
keep_arm64=$(printf '%s\n' "$exes" | grep -E '\-arm64\.exe$' | sort -V | tail -n 1 || true)
keep_x64_offline=$(printf '%s\n' "$exes" | grep -E '\-x64-offline\.exe$' | sort -V | tail -n 1 || true)

# Remove every other installer EXE from the index (keep the working-tree file).
printf '%s\n' "$exes" | while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    "$keep_x64"|"$keep_x86"|"$keep_arm64"|"$keep_x64_offline") continue ;;
  esac
  git rm --cached --quiet -- "$f"
  printf 'pre-commit: untracked superseded/legacy installer (kept on disk): %s\n' "$f" >&2
done

# Verify a retained installer is an LFS pointer, not a raw binary.
verify_lfs() {
  f="$1"
  [ -z "$f" ] && return 0
  first_line=$(git cat-file -p ":$f" 2>/dev/null | head -n 1 || true)
  case "$first_line" in
    "version https://git-lfs.github.com/spec/v1")
      : # ok: it is an LFS pointer
      ;;
    *)
      printf '\n[pre-commit ABORTED] %s is staged as a RAW file, not a Git LFS pointer.\n' "$f" >&2
      printf 'GitHub rejects >100MB raw files. Re-stage it through LFS:\n' >&2
      printf '    git rm --cached "%s" && git add "%s"\n' "$f" "$f" >&2
      printf '(ensure .gitattributes maps *.exe to lfs).\n\n' >&2
      exit 1
      ;;
  esac
}

verify_lfs "$keep_x64"
verify_lfs "$keep_x86"
verify_lfs "$keep_arm64"
verify_lfs "$keep_x64_offline"

kept=$(printf '%s\n' "$keep_x64" "$keep_x86" "$keep_arm64" "$keep_x64_offline" | grep -v '^$' | tr '\n' ' ' || true)
printf 'pre-commit: installer policy OK -> tracked (LFS): %s\n' "$kept" >&2
exit 0
