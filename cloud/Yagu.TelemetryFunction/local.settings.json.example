{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    "// APPLICATIONINSIGHTS_CONNECTION_STRING": "Your Application Insights connection string (server-side only).",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": "",

    "// STORAGE_ACCOUNT_BLOB_URI": "Blob endpoint of the dedicated storage account, e.g. https://yagubugreports.blob.core.windows.net. Leave blank to disable bug-report attachment uploads.",
    "STORAGE_ACCOUNT_BLOB_URI": "",

    "// BUGREPORT_CONTAINER": "Private container name for bug-report attachments (default: bugreports).",
    "BUGREPORT_CONTAINER": "bugreports",

    "// YAGU_APP_TOKEN": "Optional rotatable shared token. When set, requests must send a matching X-Yagu-App-Token header. Leave blank to accept unauthenticated requests (dev only).",
    "YAGU_APP_TOKEN": ""
  }
}
