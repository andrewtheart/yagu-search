  <!-- Copy the Rust cdylib next to the test assembly so the native fast-path
       is exercised under `dotnet test`. The build is gated on Cargo.toml
       existing; missing DLLs fall back to the managed path. -->
  <ItemGroup Condition="Exists('$(RustDllPath)')">
    <None Include="$(RustDllPath)">
      <Link>yagu_core.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="Exists('$(RustPdbPath)')">
    <None Include="$(RustPdbPath)">
      <Link>yagu_core.pdb</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\vendor\SharpSevenZip\SharpSevenZip\SharpSevenZip\SharpSevenZip.csproj" />
    <!-- SemanticPlanApplier (compiled into the test assembly) now uses vendored nChronic for
         natural-language date parsing, so the tests need the same reference. -->
    <ProjectReference Include="..\..\src\vendor\nChronic\Chronic\Chronic.csproj" />
  </ItemGroup>

