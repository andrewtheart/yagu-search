<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>Yagu.Benchmarks</RootNamespace>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <IsPackable>false</IsPackable>
    <!-- This project is both a BenchmarkDotNet console (run via `dotnet run`) and an
         xUnit test host for the throughput benchmarks (run via `dotnet test`).
         GenerateProgramFile=false keeps Program.Main as the sole entry point so the
         test SDK's auto-generated Main does not conflict with it. -->
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.14.*" />
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" Version="10.0.*" />
  </ItemGroup>

  <!-- xUnit test support for the throughput benchmarks (PerformanceBenchmarkTests). -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\src\Yagu\Models\SearchResult.cs" Link="Source\Models\SearchResult.cs" />
    <Compile Include="..\..\src\Yagu\Models\SearchOptions.cs" Link="Source\Models\SearchOptions.cs" />
    <Compile Include="..\..\src\Yagu\Models\SearchProgress.cs" Link="Source\Models\SearchProgress.cs" />
    <Compile Include="..\..\src\Yagu\Models\FileGroup.cs" Link="Source\Models\FileGroup.cs" />
    <Compile Include="..\..\src\Yagu\Models\BatchObservableCollection.cs" Link="Source\Models\BatchObservableCollection.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\BinaryDetector.cs" Link="Source\Helpers\BinaryDetector.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\GlobMatcher.cs" Link="Source\Helpers\GlobMatcher.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\EncodingDetector.cs" Link="Source\Helpers\EncodingDetector.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\LineTruncator.cs" Link="Source\Helpers\LineTruncator.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\SyntaxHighlighter.cs" Link="Source\Helpers\SyntaxHighlighter.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\MultilineTextShadow.cs" Link="Source\Helpers\MultilineTextShadow.cs" />
    <Compile Include="..\..\src\Yagu\Services\FileLister.cs" Link="Source\Services\FileLister.cs" />
    <Compile Include="..\..\src\Yagu\Services\ContentSearcher.cs" Link="Source\Services\ContentSearcher.cs" />
    <Compile Include="..\..\src\Yagu\Services\FileMetadataCache.cs" Link="Source\Services\FileMetadataCache.cs" />
    <Compile Include="..\..\src\Yagu\Services\SearchService.cs" Link="Source\Services\SearchService.cs" />
    <Compile Include="..\..\src\Yagu\Services\SearchRegexFactory.cs" Link="Source\Services\SearchRegexFactory.cs" />
    <Compile Include="..\..\src\Yagu\Services\SettingsService.cs" Link="Source\Services\SettingsService.cs" />
    <Compile Include="..\..\src\Yagu\Services\CloudFileHelper.cs" Link="Source\Services\CloudFileHelper.cs" />
    <Compile Include="..\..\src\Yagu\Services\TerminalShellKind.cs" Link="Source\Services\TerminalShellKind.cs" />
    <Compile Include="..\..\src\Yagu\Helpers\DiskTypeDetector.cs" Link="Source\Helpers\DiskTypeDetector.cs" />
    <!-- WorkerOcrEngine.cs (pulled in by the Services\Ocr\*.cs glob below) verifies the OCR worker's
         Authenticode signature, so AuthenticodeVerifier.cs must be compiled in too. -->
    <Compile Include="..\..\src\Yagu\Services\AuthenticodeVerifier.cs" Link="Source\Services\AuthenticodeVerifier.cs" />
    <Compile Include="..\..\src\Yagu\Services\Ocr\*.cs" Link="Source\Services\Ocr\%(Filename)%(Extension)" />
    <Compile Include="..\..\src\Yagu\Services\HotkeyService.cs" Link="Source\Services\HotkeyService.cs" />
    <Compile Include="..\..\src\Yagu\Services\EditorLauncher.cs" Link="Source\Services\EditorLauncher.cs" />
    <Compile Include="..\..\src\Yagu\Services\ZipArchiveSearcher.cs" Link="Source\Services\ZipArchiveSearcher.cs" />
    <Compile Include="..\..\src\Yagu\Services\ResultStore.cs" Link="Source\Services\ResultStore.cs" />
    <Compile Include="..\..\src\Yagu\Services\DynamicGitignoreMatcher.cs" Link="Source\Services\DynamicGitignoreMatcher.cs" />
    <Compile Include="..\..\src\Yagu\Services\SearchQueryParser.cs" Link="Source\Services\SearchQueryParser.cs" />
    <Compile Include="..\..\src\Yagu\Services\FileWatchDiagnostics.cs" Link="Source\Services\FileWatchDiagnostics.cs" />
    <Compile Include="..\..\src\Yagu\Services\LogService.cs" Link="Source\Services\LogService.cs" />
    <Compile Include="..\..\src\Yagu\Services\DirectOutputSink.cs" Link="Source\Services\DirectOutputSink.cs" />
    <Compile Include="..\..\src\Yagu\Services\ResultStoreTempLocationService.cs" Link="Source\Services\ResultStoreTempLocationService.cs" />
    <Compile Include="..\..\src\Yagu\Native\NativeSearcher.cs" Link="Source\Native\NativeSearcher.cs" />
    <Compile Include="..\..\src\Yagu\Native\EverythingSdk.cs" Link="Source\Native\EverythingSdk.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\vendor\SharpSevenZip\SharpSevenZip\SharpSevenZip\SharpSevenZip.csproj" />
  </ItemGroup>

  <ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\..\src\yagu-core\target\release\yagu_core.dll')">
    <None Include="$(MSBuildThisFileDirectory)..\..\src\yagu-core\target\release\yagu_core.dll">
      <Link>yagu_core.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
