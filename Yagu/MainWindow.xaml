<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Yagu.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Yagu.ViewModels"
    xmlns:models="using:Yagu.Models"
    xmlns:tcb="using:TextControlBoxNS"
    Title="Yagu - Yet Another Grep Utility">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop"
          PreviewKeyDown="OnRootGridPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="Auto" />  <!-- Custom title bar -->
            <RowDefinition Height="Auto" />  <!-- Admin banner -->
            <RowDefinition Height="Auto" />  <!-- Search card -->
            <RowDefinition x:Name="ProgressRow" Height="Auto" />  <!-- Status / progress -->
            <RowDefinition x:Name="SplitPaneRow" Height="*" />     <!-- Split pane -->
            <RowDefinition x:Name="StatusBarRow" Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0,148,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE721;" FontSize="16" />
                <TextBlock x:Name="AppTitleText" Text="Yagu - Yet Another Grep Utility" Style="{ThemeResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <StackPanel x:Name="TitleBarActions" Grid.Row="0" Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" HorizontalAlignment="Right"
                    Margin="0,0,156,0" Canvas.ZIndex="100">
            <Button Click="OnOpenCredits" VerticalAlignment="Center"
                    Width="36" Height="32" MinWidth="0" Padding="0"
                    Background="Transparent" BorderThickness="0" Foreground="White"
                    ToolTipService.ToolTip="About Yagu">
                <FontIcon Glyph="&#xE897;" FontSize="14" Foreground="White" />
            </Button>
            <Button Click="OnOpenSettings" VerticalAlignment="Center"
                    Width="36" Height="32" MinWidth="0" Padding="0"
                    Background="Transparent" BorderThickness="0" Foreground="White"
                    ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="White" />
            </Button>
        </StackPanel>

        <!-- Admin elevation banner (hidden when running elevated) -->
        <Border x:Name="AdminBanner" Grid.Row="1" Visibility="Collapsed"
                Background="#332000" Padding="10,4,10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Warning icon + text -->
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FFD54F" VerticalAlignment="Center" />
                    <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Run Text="Limited access" />
                        <Run Text="  " />
                        <Run Text="Some files may not be readable without administrator privileges." FontWeight="Normal" />
                    </TextBlock>
                </StackPanel>
                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Left" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button Content="Learn more..." FontSize="12" Padding="6,1" Click="OnAdminLearnMore" />
                    <Button Content="Restart as Admin" FontSize="12" Padding="6,1" Click="OnRestartAsAdmin" />
                    <Button Content="Don't show again" FontSize="12" Padding="6,1" Click="OnDontShowAdminWarningAgain" />
                </StackPanel>
                <!-- Close button -->
                <Button Grid.Column="2" Click="OnAdminBannerCloseClick"
                        Background="Transparent" BorderThickness="0" Padding="6,2"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>
        </Border>

        <!-- Search controls card -->
        <Border Grid.Row="2" Margin="16,10,16,4" Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="10">
                <!-- Directory bar -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8B7;" FontSize="16" VerticalAlignment="Center" Opacity="0.7" />
                    <AutoSuggestBox
                        x:Name="DirectoryBox" Grid.Column="1"
                        PlaceholderText="Directory to search (e.g. D:\projects\myapp)"
                        Text="{x:Bind ViewModel.Directory, Mode=TwoWay}"
                        ItemsSource="{x:Bind ViewModel.DirectorySuggestions, Mode=OneWay}"
                        TextChanged="OnDirectoryTextChanged"
                        SuggestionChosen="OnDirectorySuggestionChosen"
                        QuerySubmitted="OnDirectoryQuerySubmitted" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                        <Button Click="OnBrowseDirectory" ToolTipService.ToolTip="Browse for folder" Padding="8,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xED25;" FontSize="14" />
                                <TextBlock Text="Browse" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PinButton" Click="OnPinToggle"
                                      ToolTipService.ToolTip="Minimize to system tray when window loses focus"
                                      Padding="8,6">
                            <FontIcon x:Name="PinIcon" Glyph="&#xE77A;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search bar -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE721;" FontSize="16" VerticalAlignment="Center" Opacity="0.7" />
                    <AutoSuggestBox
                        x:Name="QueryBox" Grid.Column="1"
                        PlaceholderText="Search query (Enter to run)"
                        Text="{x:Bind ViewModel.Query, Mode=TwoWay}"
                        ItemsSource="{x:Bind ViewModel.SearchHistory, Mode=OneWay}"
                        QuerySubmitted="OnQuerySubmitted"
                        TextChanged="OnQueryTextChanged"
                        LostFocus="OnQueryLostFocus"
                        KeyDown="OnQueryKeyDown" />
                    <Button x:Name="SearchCancelButton" Grid.Column="2" Click="OnSearchCancelClick" Style="{ThemeResource AccentButtonStyle}" Padding="12,6"
                            ToolTipService.ToolTip="Search (F5)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5" />
                        </Button.KeyboardAccelerators>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="SearchCancelIcon" Glyph="&#xE721;" FontSize="14" />
                            <TextBlock x:Name="SearchCancelLabel" Text="Search" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Advanced options (collapsed by default) -->
                <Expander x:Name="AdvancedOptionsExpander"
                          IsExpanded="False" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch" Padding="0"
                          MinHeight="0" FontSize="12"
                          Expanding="OnAdvancedOptionsExpanding"
                          Collapsed="OnAdvancedOptionsCollapsed">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE76C;" FontSize="10"
                                      RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <RotateTransform x:Name="ChevronRotate" Angle="-90" />
                                </FontIcon.RenderTransform>
                            </FontIcon>
                            <TextBlock Text="Advanced Options" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Spacing="10" Padding="8,6,8,8">
                        <!-- Options row -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Content="Case sensitive" IsChecked="{x:Bind ViewModel.CaseSensitive, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Regex" IsChecked="{x:Bind ViewModel.UseRegex, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Search archives" IsChecked="{x:Bind ViewModel.SearchInsideArchives, Mode=TwoWay}"
                                      VerticalAlignment="Center" MinWidth="0"
                                      ToolTipService.ToolTip="Searches inside ZIP archives for text matches. This has a performance penalty — only enable if you expect results inside ZIP files." />
                            <DropDownButton Content="{x:Bind ViewModel.ArchiveExtensionsSummary, Mode=OneWay}"
                                            VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="ZIP-like extensions to bypass from skip list when archive search is on">
                                <DropDownButton.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <StackPanel Width="320" Spacing="2">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Archive Extensions" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <HyperlinkButton Grid.Column="1" Content="All" Click="OnArchiveExtSelectAll" Padding="4,2" />
                                                <HyperlinkButton Grid.Column="2" Content="None" Click="OnArchiveExtSelectNone" Padding="4,2" />
                                            </Grid>
                                            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                                <ItemsRepeater x:Name="ArchiveExtRepeater"
                                                               ItemsSource="{x:Bind ViewModel.ArchiveExtensionItems, Mode=OneWay}">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="0" />
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SkipExtensionItem">
                                                            <CheckBox IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                      MinWidth="0" MinHeight="0" Padding="6,2"
                                                                      Checked="OnArchiveExtToggled" Unchecked="OnArchiveExtToggled">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{x:Bind Extension}" FontFamily="Consolas" Width="80" />
                                                                    <TextBlock Text="{x:Bind Category}" Opacity="0.5" FontSize="11" />
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.SearchModeIndex, Mode=TwoWay}" VerticalAlignment="Center">
                                <x:String>Content + Names</x:String>
                                <x:String>Content only</x:String>
                                <x:String>File names only</x:String>
                            </ComboBox>
                            <DropDownButton Content="{x:Bind ViewModel.SkipExtensionsSummary, Mode=OneWay}"
                                            VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="Extensions to skip during search">
                                <DropDownButton.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <StackPanel Width="320" Spacing="2">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Skip Extensions" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <HyperlinkButton Grid.Column="1" Content="All" Click="OnSkipExtSelectAll" Padding="4,2" />
                                                <HyperlinkButton Grid.Column="2" Content="None" Click="OnSkipExtSelectNone" Padding="4,2" />
                                            </Grid>
                                            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                                <ItemsRepeater x:Name="SkipExtRepeater"
                                                               ItemsSource="{x:Bind ViewModel.SkipExtensionItems, Mode=OneWay}">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="0" />
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SkipExtensionItem">
                                                            <CheckBox IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                      MinWidth="0" MinHeight="0" Padding="6,2"
                                                                      Checked="OnSkipExtToggled" Unchecked="OnSkipExtToggled">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{x:Bind Extension}" FontFamily="Consolas" Width="50" />
                                                                    <TextBlock Text="{x:Bind Category}" Opacity="0.5" FontSize="11" />
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <CheckBox Content="Skip binary" IsChecked="{x:Bind ViewModel.SkipBinary, Mode=TwoWay}"
                                      VerticalAlignment="Center" MinWidth="0"
                                      ToolTipService.ToolTip="Skip files detected as binary during content search" />
                        </StackPanel>

                        <!-- Filter row -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <TextBox PlaceholderText="e.g. ts,js,py or *.cs"
                                         Text="{x:Bind ViewModel.IncludeGlobs, Mode=TwoWay}"
                                         Padding="72,4,8,4" FontStyle="Italic"
                                         TextChanged="OnFilterBoxTextChanged" />
                                <Border Background="#0078D4" CornerRadius="8" Padding="8,2"
                                        VerticalAlignment="Center" HorizontalAlignment="Left"
                                        Margin="6,0,0,0" IsHitTestVisible="True"
                                        ToolTipService.ToolTip="Extensions or file path / folder path substrings to include. Absence of a value in the field implies everything will be included.">
                                    <TextBlock Text="Include" FontSize="11" Foreground="White"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                            <Grid Grid.Column="1">
                                <TextBox PlaceholderText="e.g. node_modules;bin;obj"
                                         Text="{x:Bind ViewModel.ExcludeGlobs, Mode=TwoWay}"
                                         Padding="72,4,8,4" FontStyle="Italic"
                                         TextChanged="OnFilterBoxTextChanged" />
                                <Border Background="#0078D4" CornerRadius="8" Padding="8,2"
                                        VerticalAlignment="Center" HorizontalAlignment="Left"
                                        Margin="6,0,0,0" IsHitTestVisible="True"
                                        ToolTipService.ToolTip="Extensions or file path / folder path substrings to exclude. Absence of a value in the field implies nothing will be excluded.">
                                    <TextBlock Text="Exclude" FontSize="11" Foreground="White"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Size + date filters row -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Content="Limit size"
                                      IsChecked="{x:Bind ViewModel.IsFileSizeFilterEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      ToolTipService.ToolTip="When off, search includes files of any size." />
                            <StackPanel Grid.Column="1" Spacing="2" Width="100">
                                <TextBlock Text="Min MB" FontSize="11" Opacity="0.75" />
                                <NumberBox Value="{x:Bind ViewModel.MinFileSizeMB, Mode=TwoWay}"
                                           IsEnabled="{x:Bind ViewModel.IsFileSizeFilterEnabled, Mode=OneWay}"
                                           Minimum="0"
                                           SpinButtonPlacementMode="Hidden"
                                           PlaceholderText="0"
                                           ToolTipService.ToolTip="Minimum file size in MB. 0 includes files of any smaller size." />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2" Width="100">
                                <TextBlock Text="Max MB" FontSize="11" Opacity="0.75" />
                                <NumberBox Value="{x:Bind ViewModel.MaxFileSizeMB, Mode=TwoWay}"
                                           IsEnabled="{x:Bind ViewModel.IsFileSizeFilterEnabled, Mode=OneWay}"
                                           Minimum="0"
                                           SpinButtonPlacementMode="Hidden"
                                           PlaceholderText="0"
                                           ToolTipService.ToolTip="Maximum file size in MB. 0 disables the upper size limit." />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBlock Text="Created after" FontSize="11" Opacity="0.75" />
                                <CalendarDatePicker Date="{x:Bind ViewModel.CreatedAfterDate, Mode=TwoWay}"
                                                    PlaceholderText="Any" HorizontalAlignment="Stretch"
                                                    ToolTipService.ToolTip="Only include files created on or after this date." />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="2">
                                <TextBlock Text="Created before" FontSize="11" Opacity="0.75" />
                                <CalendarDatePicker Date="{x:Bind ViewModel.CreatedBeforeDate, Mode=TwoWay}"
                                                    PlaceholderText="Any" HorizontalAlignment="Stretch"
                                                    ToolTipService.ToolTip="Only include files created on or before this date." />
                            </StackPanel>
                            <StackPanel Grid.Column="5" Spacing="2">
                                <TextBlock Text="Modified after" FontSize="11" Opacity="0.75" />
                                <CalendarDatePicker Date="{x:Bind ViewModel.ModifiedAfterDate, Mode=TwoWay}"
                                                    PlaceholderText="Any" HorizontalAlignment="Stretch"
                                                    ToolTipService.ToolTip="Only include files modified on or after this date." />
                            </StackPanel>
                            <StackPanel Grid.Column="6" Spacing="2">
                                <TextBlock Text="Modified before" FontSize="11" Opacity="0.75" />
                                <CalendarDatePicker Date="{x:Bind ViewModel.ModifiedBeforeDate, Mode=TwoWay}"
                                                    PlaceholderText="Any" HorizontalAlignment="Stretch"
                                                    ToolTipService.ToolTip="Only include files modified on or before this date." />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Status / progress -->
        <StackPanel Grid.Row="3" Padding="16,2,16,2" Spacing="4">
            <ProgressBar
                Visibility="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                Maximum="{x:Bind ViewModel.TotalFiles, Mode=OneWay}"
                Value="{x:Bind ViewModel.FilesScanned, Mode=OneWay}"
                IsIndeterminate="False" CornerRadius="3" Height="6"
                ToolTipService.ToolTip="{x:Bind ViewModel.ProgressTooltip, Mode=OneWay}" />
            <TextBlock Foreground="OrangeRed"
                       Visibility="{x:Bind ViewModel.HasFallbackReason, Mode=OneWay}"
                       Text="{x:Bind ViewModel.FallbackReason, Mode=OneWay}" />
            <TextBlock Foreground="Red"
                       Visibility="{x:Bind ViewModel.HasErrorText, Mode=OneWay}"
                       Text="{x:Bind ViewModel.ErrorText, Mode=OneWay}" />
        </StackPanel>

        <!-- Split pane: results + preview -->
        <Grid x:Name="SplitPaneGrid" Grid.Row="4" Margin="16,2,20,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ResultsColumn" Width="*" MinWidth="200" />
                <ColumnDefinition x:Name="SplitterColumn" Width="0" />
                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Results panel card -->
            <Border x:Name="ResultsPanelBorder" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="12,8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8CB;" FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
                        <TextBlock Text="Sort:" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SortModeIndex, Mode=TwoWay}" VerticalAlignment="Center" FontSize="12">
                            <x:String>None</x:String>
                            <x:String># Matches</x:String>
                            <x:String>Date Modified</x:String>
                            <x:String>File Size</x:String>
                            <x:String>File Name</x:String>
                        </ComboBox>
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SortDirectionIndex, Mode=TwoWay}" VerticalAlignment="Center" FontSize="12">
                            <x:String>Desc</x:String>
                            <x:String>Asc</x:String>
                        </ComboBox>
                        <FontIcon Glyph="&#xE8FD;" FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
                        <TextBlock Text="Group:" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                        <DropDownButton Content="{x:Bind ViewModel.GroupModeLabel, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Padding="8,4" ToolTipService.ToolTip="Group results by…">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="None" Click="OnGroupModeNone" />
                                    <MenuFlyoutItem Text="Folder" Click="OnGroupModeFolder" />
                                    <MenuFlyoutSubItem Text="Date range...">
                                        <MenuFlyoutItem Text="Date range (Modified)" Click="OnGroupModeDateRangeModified" />
                                        <MenuFlyoutItem Text="Date range (Created)" Click="OnGroupModeDateRangeCreated" />
                                        <MenuFlyoutItem Text="Date range (Modified + Created)" Click="OnGroupModeDateRangeModifiedCreated" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutItem Text="Extension" Click="OnGroupModeExtension" />
                                    <MenuFlyoutItem Text="File size" Click="OnGroupModeFileSize" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <DropDownButton Content="{x:Bind ViewModel.GroupSortDirectionLabel, Mode=OneWay}"
                                        VerticalAlignment="Center" FontSize="12" Padding="8,4"
                                        ToolTipService.ToolTip="Sort group headers">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Ascending" Click="OnGroupSortAscending" />
                                    <MenuFlyoutItem Text="Descending" Click="OnGroupSortDescending" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <CheckBox x:Name="AutoScrollResultsCheckBox"
                                  Content="Auto-scroll"
                                  IsChecked="False"
                                  VerticalAlignment="Center"
                                  FontSize="12"
                                  MinWidth="0"
                                  MinHeight="0"
                                  Padding="4,0,0,0"
                                  Checked="OnAutoScrollResultsChanged"
                                  Unchecked="OnAutoScrollResultsChanged"
                                  ToolTipService.ToolTip="Follow new results as they arrive" />
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Context:" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                            <NumberBox Value="{x:Bind ViewModel.ContextLines, Mode=TwoWay}" Minimum="0" Maximum="20"
                                       SpinButtonPlacementMode="Compact" MinWidth="64" Width="64" FontSize="12" />
                            <Button Click="OnClearResults" Background="Transparent" BorderThickness="0"
                                    Padding="6,4" VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Clear all results (Ctrl+Shift+Delete)">
                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                            </Button>
                        </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DegradedNoticeText, Mode=OneWay}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="12" Foreground="DarkOrange" Opacity="0.9" Margin="8,0,4,0" />
                        <Button x:Name="ExpandResultsButton" Grid.Column="2"
                                Click="OnExpandResultsPanel"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,4" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Expand file list / collapse preview">
                            <FontIcon x:Name="ExpandResultsIcon" Glyph="&#xE740;" FontSize="12" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="8,6" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="SelectAllFilesCheckBox"
                                  ToolTipService.ToolTip="Select / deselect all files"
                                  MinWidth="32" MinHeight="0" Padding="0"
                                  VerticalAlignment="Center"
                                  Checked="OnSelectAllFilesChecked"
                                  Unchecked="OnSelectAllFilesUnchecked" />
                        <Grid Grid.Column="1">
                            <TextBox PlaceholderText="Filter files…"
                                     Text="{x:Bind ViewModel.FileNameFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="30,4,8,4" FontSize="12" />
                            <FontIcon Glyph="&#xE71C;" FontSize="12" Opacity="0.65"
                                      HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Margin="10,0,0,0" IsHitTestVisible="False" />
                        </Grid>
                        <DropDownButton Grid.Column="2"
                                        Content="{x:Bind ViewModel.DateRangeFilterLabel, Mode=OneWay}"
                                        VerticalAlignment="Center" FontSize="12" Padding="8,4"
                                        ToolTipService.ToolTip="Filter files by modified or created date">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Any date" Click="OnDateFilterNone" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Last day" Click="OnDateFilterPastDay" />
                                    <MenuFlyoutItem Text="Last week" Click="OnDateFilterPastWeek" />
                                    <MenuFlyoutItem Text="Last 2 weeks" Click="OnDateFilterPastTwoWeeks" />
                                    <MenuFlyoutItem Text="Last month" Click="OnDateFilterPastMonth" />
                                    <MenuFlyoutItem Text="Last 3 months" Click="OnDateFilterPastThreeMonths" />
                                    <MenuFlyoutItem Text="Last 6 months" Click="OnDateFilterPastSixMonths" />
                                    <MenuFlyoutItem Text="Last 9 months" Click="OnDateFilterPastNineMonths" />
                                    <MenuFlyoutItem Text="Last year" Click="OnDateFilterPastYear" />
                                    <MenuFlyoutItem Text="Last 2 years" Click="OnDateFilterPastTwoYears" />
                                    <MenuFlyoutItem Text="Last 3 years" Click="OnDateFilterPastThreeYears" />
                                    <MenuFlyoutItem Text="Last 5 years" Click="OnDateFilterPastFiveYears" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </Grid>

                    <ListView
                        x:Name="ResultsList"
                        Grid.Row="2"
                        SelectionMode="None"
                        ShowsScrollingPlaceholders="True"
                        IsItemClickEnabled="True"
                        ItemClick="OnResultItemClick"
                        DoubleTapped="OnResultDoubleTapped"
                        KeyDown="OnResultsListKeyDown"
                        PointerPressed="OnResultsListPointerPressed"
                        RightTapped="OnResultsListRightTapped"
                        ItemsSource="{x:Bind ViewModel.ResultGroups, Mode=OneWay}"
                        Padding="4,0">
                        <ListView.ContextFlyout>
                            <MenuFlyout Opening="OnResultsContextMenuOpening">
                                <MenuFlyoutItem x:Name="CtxPreviewSelected" Text="Preview selected" Click="OnPreviewSelectedFiles">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem x:Name="CtxCopyPaths" Text="Copy File Path" Click="OnCopySelectedFilePaths">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="CtxCopyWithContent" Text="Copy File With Content" Click="OnCopySelectedFilesWithContent">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem x:Name="CtxSavePaths" Text="Save File Path…" Click="OnSaveSelectedFilePaths">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="CtxSaveWithContent" Text="Save File With Content…" Click="OnSaveSelectedFilesWithContent">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </ListView.ContextFlyout>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FileGroup">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind GroupHeaderText, Mode=OneWay}"
                                               Visibility="{x:Bind HasGroupHeader, Mode=OneWay}"
                                               FontWeight="Bold" FontSize="13" Padding="4,10,0,2"
                                               Opacity="0.8">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{ThemeResource SystemAccentColor}" />
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}" Expanding="OnFileGroupExpanding">
                                    <Expander.Header>
                                        <Grid PointerPressed="OnFileGroupHeaderPointerPressed" PointerReleased="OnFileGroupHeaderPointerReleased" Tapped="OnFileGroupHeaderTapped" DoubleTapped="OnFileGroupHeaderDoubleTapped" Tag="{x:Bind FilePath}" Background="Transparent">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout Opening="OnFileHeaderContextMenuOpening">
                                                    <MenuFlyoutItem Text="Preview selected" Click="OnPreviewSelectedFiles" Tag="{x:Bind FilePath}">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A1;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Copy Full Path" Click="OnCopyFileGroupPath" Tag="{x:Bind FilePath}">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Copy Selected File Paths" Click="OnCopySelectedFilePaths">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Copy Selected Files With Content" Click="OnCopySelectedFilesWithContent">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Save Selected File Paths…" Click="OnSaveSelectedFilePaths">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Save Selected Files With Content…" Click="OnSaveSelectedFilesWithContent">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="650" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                        <CheckBox AutomationProperties.AutomationId="FileGroupCheckBox"
                                                  IsChecked="{x:Bind AllSelected, Mode=OneWay}" MinWidth="32" MinHeight="0" Padding="0" VerticalAlignment="Center"
                                                  Click="OnFileGroupCheckBoxClicked" />
                                        <!-- Match count badge -->
                                        <Border Grid.Column="1" Background="#1A6B5A" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" Margin="0,0,10,0" MinWidth="50">
                                            <TextBlock VerticalAlignment="Center" HorizontalTextAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#B0E0D0">
                                                <Run Text="{x:Bind MatchCount}" /><Run Text=" matches" />
                                            </TextBlock>
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                                <TextBlock Opacity="0.45" FontSize="11">
                                                    <Run Text="Modified:" /><Run Text=" " /><Run Text="{x:Bind FormattedDate}" /><Run Text=" | Size:" /><Run Text=" " /><Run Text="{x:Bind FormattedSize}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Directory path right-aligned -->
                                        <TextBlock Grid.Column="3" Text="{x:Bind DirectoryName}"
                                                   ToolTipService.ToolTip="{x:Bind DirectoryName}"
                                                   Opacity="0.45" FontSize="11" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   HorizontalAlignment="Left" Margin="12,0,4,0" />
                                        <Button Grid.Column="4" Click="OnShowFileGroupInExplorer" Tag="{x:Bind FilePath}"
                                                Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                                Background="Transparent" BorderThickness="0"
                                                VerticalAlignment="Center" Margin="4,0,0,0"
                                                ToolTipService.ToolTip="Open containing folder in Explorer">
                                            <FontIcon Glyph="&#xED25;" FontSize="12" />
                                        </Button>
                                        </Grid>
                                    </Expander.Header>
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{x:Bind VisibleResults}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:SearchResult">
                                                    <Grid Padding="0,2,8,2" ColumnSpacing="3" Tapped="OnMatchLineTapped" Background="Transparent">
                                                        <Grid.ContextFlyout>
                                                            <MenuFlyout>
                                                                <MenuFlyoutItem Text="Copy Selected Lines" Click="OnCopySelectedLines">
                                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                                <MenuFlyoutItem Text="Export Selected to File…" Click="OnExportSelectedLines">
                                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                                <MenuFlyoutSeparator />
                                                                <MenuFlyoutItem Text="Copy This Line" Click="OnCopySingleLine" />
                                                            </MenuFlyout>
                                                        </Grid.ContextFlyout>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="28" MinHeight="0" Padding="0" VerticalAlignment="Center"
                                                                  Click="OnMatchLineCheckBoxClicked" />
                                                        <Border Grid.Column="1" MinWidth="34" Padding="5,1" Margin="-2,0,2,0"
                                                                CornerRadius="4"
                                                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                BorderBrush="{ThemeResource SystemAccentColor}"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind LineNumber}"
                                                                       HorizontalAlignment="Center"
                                                                       TextAlignment="Center"
                                                                       FontFamily="Consolas"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                        </Border>
                                                        <RichTextBlock Grid.Column="2" TextTrimming="CharacterEllipsis" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="False" Loaded="OnMatchLineLoaded" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <HyperlinkButton Content="{x:Bind ShowMoreText, Mode=OneWay}"
                                                         Visibility="{x:Bind HasMore, Mode=OneWay}"
                                                         Click="OnShowMoreClicked"
                                                         Padding="4,4,0,2" FontSize="12" />
                                    </StackPanel>
                                </Expander>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border x:Name="SplitterBorder" Grid.Column="1" Width="8" Background="Transparent"
                    Visibility="Collapsed"
                    PointerPressed="OnSplitterPressed"
                    PointerMoved="OnSplitterMoved"
                    PointerReleased="OnSplitterReleased"
                    PointerEntered="OnSplitterPointerEntered"
                    PointerExited="OnSplitterPointerExited">
                <!-- Grip dots indicating the splitter can be dragged -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="3" Opacity="0.4">
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Preview panel card -->
            <Border x:Name="PreviewPanelBorder" Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Padding="12,8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="PreviewToolbarContent" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                            <!-- File identity -->
                            <FontIcon Glyph="&#xE7B3;" FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
                            <TextBlock x:Name="PreviewFileLabel" VerticalAlignment="Center" FontSize="12" Opacity="0.7"
                                       TextTrimming="CharacterEllipsis" MaxWidth="300" />
                            <Button x:Name="CopyPreviewFilePathButton" Click="OnCopyPreviewFilePath" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Copy full file path">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                            </Button>
                            <AppBarSeparator x:Name="PreviewToolbarSeparator" />

                            <!-- View group -->
                            <Button x:Name="FullFileButton" Click="OnShowFullFile" FontSize="12" Padding="8,4" ToolTipService.ToolTip="Show full file content">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                                    <TextBlock Text="Full File" />
                                </StackPanel>
                            </Button>
                            <DropDownButton x:Name="LayoutDropDown" Content="Layout" VerticalAlignment="Center" FontSize="12"
                                             ToolTipService.ToolTip="Multi-select preview layout">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <ToggleMenuFlyoutItem x:Name="LayoutConcatenated" Text="Concatenated" Click="OnLayoutOptionClicked" />
                                        <ToggleMenuFlyoutItem x:Name="LayoutMultiHighlight" Text="Multi-highlight" Click="OnLayoutOptionClicked" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <ToggleButton x:Name="WordWrapToggle" FontSize="12" Padding="8,4"
                                          ToolTipService.ToolTip="Toggle word wrap in preview"
                                          IsChecked="{x:Bind ViewModel.PreviewWordWrap, Mode=TwoWay}"
                                          Click="OnWordWrapToggled">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE8B3;" FontSize="12" />
                                    <TextBlock Text="Wrap" />
                                </StackPanel>
                            </ToggleButton>
                            <AppBarSeparator />

                            <!-- Action group -->
                            <Button x:Name="OpenInDefaultAppButton" Click="OnOpenInDefaultApp" FontSize="12" Padding="8,4" ToolTipService.ToolTip="Open with default Windows application">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                                    <TextBlock Text="Open" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="OpenInEditorButton" Click="OnOpenInEditor" FontSize="12" Padding="8,4" ToolTipService.ToolTip="Edit file in built-in editor">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                    <TextBlock Text="Edit" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ShowInExplorerButton" Click="OnShowInExplorer" FontSize="12" Padding="8,4" ToolTipService.ToolTip="Open containing folder in Explorer">
                                <FontIcon Glyph="&#xED25;" FontSize="12" />
                            </Button>
                            <Button x:Name="ExpandAllSectionsButton" Click="OnExpandAllSections" FontSize="12" Padding="8,4"
                                    ToolTipService.ToolTip="Expand and render all collapsed sections" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE740;" FontSize="12" />
                                    <TextBlock Text="Expand All" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ClearPreviewButton" Click="OnClearPreview" FontSize="12" Padding="8,4" ToolTipService.ToolTip="Clear all files from preview">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE894;" FontSize="12" />
                                    <TextBlock Text="Clear" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="FindReplaceButton" Click="OnOpenFindReplaceBar" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Find &amp; Replace (Ctrl+H)">
                                <FontIcon Glyph="&#xE721;" FontSize="12" />
                            </Button>
                            <StackPanel x:Name="PreviewContextPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Preview Context:" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.PreviewContextLines, Mode=TwoWay}" Minimum="0"
                                           SpinButtonPlacementMode="Compact" MinWidth="64" Width="64" FontSize="12" />
                            </StackPanel>

                            <!-- Editor-mode group (visible only when editing) -->
                            <AppBarSeparator x:Name="EditorSeparator" Visibility="Collapsed" />
                            <Button x:Name="SavePreviewEditButton" Click="OnSavePreviewEdit" FontSize="12" Padding="8,4"
                                    ToolTipService.ToolTip="Save changes to file" Visibility="Collapsed" IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                    <TextBlock Text="Save" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ClosePreviewEditButton" Click="OnClosePreviewEdit" FontSize="12" Padding="8,4"
                                    ToolTipService.ToolTip="Close editor and return to preview" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE72B;" FontSize="12" />
                                    <TextBlock Text="Back" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel x:Name="MatchNavPanel" Grid.Column="1" Visibility="Collapsed"
                                    Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Border Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    BorderBrush="{ThemeResource SystemAccentColor}"
                                    BorderThickness="1" CornerRadius="6" Padding="6,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="MatchNavLabel" FontSize="11" Opacity="0.8"
                                               VerticalAlignment="Center" Margin="2,0" />
                                    <Button x:Name="PrevMatchButton" Click="OnPrevMatch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Previous match (Shift+Enter) · Ctrl+Click to jump multiple">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="NextMatchButton" Click="OnNextMatch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Next match (Enter) · Ctrl+Click to jump multiple">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button x:Name="ExpandPreviewButton" Grid.Column="2"
                                Click="OnExpandPreviewPanel"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,4" VerticalAlignment="Center" Margin="6,0,0,0"
                                ToolTipService.ToolTip="Expand preview / collapse file list">
                            <FontIcon x:Name="ExpandPreviewIcon" Glyph="&#xE740;" FontSize="12" />
                        </Button>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Find / Replace bar -->
                        <Border x:Name="FindBar" Visibility="Collapsed" Grid.Row="0"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1" Padding="8,6">
                            <Grid HorizontalAlignment="Right">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4">
                                    <TextBox x:Name="FindTextBox" PlaceholderText="Find…" Width="220" FontSize="12"
                                             KeyDown="OnFindTextBoxKeyDown" TextChanged="OnFindTextBoxTextChanged"
                                             IsSpellCheckEnabled="False" IsTextPredictionEnabled="False" />
                                    <Button Click="OnFindPrevious" ToolTipService.ToolTip="Previous (Shift+Enter)" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button Click="OnFindNext" ToolTipService.ToolTip="Next (Enter)" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                    <CheckBox x:Name="FindMatchCaseCheckBox" Content="Aa" FontSize="11" MinWidth="0" Padding="4,0"
                                              ToolTipService.ToolTip="Match case" Unchecked="OnFindOptionChanged" Checked="OnFindOptionChanged" />
                                    <ToggleButton x:Name="FindReplaceToggle" Click="OnFindReplaceToggle" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                                  ToolTipService.ToolTip="Toggle Replace (Ctrl+H)">
                                        <FontIcon Glyph="&#xE8AC;" FontSize="12" />
                                    </ToggleButton>
                                    <TextBlock x:Name="FindStatusText" VerticalAlignment="Center" FontSize="11" Opacity="0.6" Margin="4,0,0,0" />
                                    <Button Click="OnCloseFindBar" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            ToolTipService.ToolTip="Close (Escape)">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                                <StackPanel x:Name="ReplaceRow" Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0" Visibility="Collapsed">
                                    <TextBox x:Name="ReplaceTextBox" PlaceholderText="Replace…" Width="220" FontSize="12"
                                             KeyDown="OnReplaceTextBoxKeyDown"
                                             IsSpellCheckEnabled="False" IsTextPredictionEnabled="False" />
                                    <Button x:Name="ReplaceOneButton" Click="OnReplaceOne" ToolTipService.ToolTip="Replace current match (Enter)" FontSize="12" Padding="8,4">
                                        <TextBlock Text="Replace" />
                                    </Button>
                                    <Button x:Name="ReplaceAllButton" Click="OnReplaceAll" ToolTipService.ToolTip="Replace all in this file" FontSize="12" Padding="8,4">
                                        <TextBlock Text="All" />
                                    </Button>
                                    <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,2" />
                                    <Button x:Name="ReplaceInFilesButton" Click="OnReplaceInAllFiles"
                                            ToolTipService.ToolTip="Replace in all result files on disk"
                                            FontSize="12" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8AC;" FontSize="12" />
                                            <TextBlock Text="All Files" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="PreviewScrollViewer" Grid.Row="1" Padding="16,12"
                                      HorizontalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel x:Name="PreviewMessagePanel">
                                    <RichTextBlock x:Name="PreviewBlock" FontFamily="Consolas" TextWrapping="NoWrap" />
                                    <Button x:Name="PreviewBackButton" Visibility="Collapsed"
                                            Click="OnPreviewBackClick" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE72B;" FontSize="12" />
                                            <TextBlock Text="Back to preview" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <StackPanel x:Name="PreviewSectionsPanel" Visibility="Collapsed" Spacing="8" />
                                <StackPanel x:Name="PreviewLoadingPanel" Visibility="Collapsed"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                                            Margin="0,48,0,0">
                                    <ProgressRing x:Name="PreviewLoadingRing" IsActive="False" Width="36" Height="36" />
                                    <TextBlock x:Name="PreviewLoadingText" Text="Loading preview…"
                                               HorizontalAlignment="Center" Opacity="0.7" FontSize="13" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- Sticky file header: shown when the actual file expander header
                             of the section currently in view has scrolled out the top.
                             Content is built dynamically from BuildPreviewSectionHeader so
                             it mirrors the per-file action buttons (Show full file, Copy
                             path, Open, Edit, Show in Explorer, Dismiss). -->
                        <Border x:Name="StickyFileHeader" Grid.Row="1" Visibility="Collapsed"
                                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1"
                                Padding="12,6"
                                Tapped="StickyFileHeader_Tapped" />

                        <Canvas x:Name="ActiveMatchOverlay" Grid.Row="1"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Canvas.ZIndex="20"
                            IsHitTestVisible="False" Visibility="Collapsed">
                            <Border x:Name="ActiveMatchBand"
                                Canvas.ZIndex="20"
                                Height="18"
                                Background="#22FF6A00"
                                BorderBrush="#FFFF4500"
                                BorderThickness="4,0,0,0"
                                CornerRadius="3" />
                            <Border x:Name="ActiveMatchWordMarker"
                                Canvas.ZIndex="21"
                                Height="18"
                                MinWidth="12"
                                Background="#1AFF4500"
                                BorderBrush="#FFFF4500"
                                BorderThickness="0,0,0,2"
                                CornerRadius="2" />
                        </Canvas>

                        <!-- Progress overlay for "Show all files" -->
                        <Grid x:Name="PreviewProgressOverlay" Grid.Row="1" Visibility="Collapsed">
                            <Border Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    Opacity="0.85" />
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <ProgressRing x:Name="PreviewProgressRing" IsActive="False" Width="40" Height="40" />
                                <TextBlock x:Name="PreviewProgressText" Text="Loading files…"
                                           HorizontalAlignment="Center" FontSize="14" />
                                <TextBlock x:Name="PreviewProgressPercent" Text="0%"
                                           HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <!-- Per-section match navigation overlay (file-level, stays visible during scroll) -->
                        <StackPanel x:Name="SectionNavOverlay" Grid.Row="1" Visibility="Collapsed"
                                    Orientation="Horizontal" Spacing="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="0,0,8,8" Opacity="0.75"
                                    PointerEntered="OnSectionNavPointerEntered"
                                    PointerExited="OnSectionNavPointerExited">
                            <Border Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    BorderBrush="{ThemeResource SystemAccentColor}"
                                    BorderThickness="1" CornerRadius="6" Padding="6,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="SectionNavLabel" FontSize="11" Opacity="0.8"
                                               VerticalAlignment="Center" Margin="2,0" />
                                    <Button x:Name="SectionPrevButton" Click="OnSectionNavPrev"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Previous match in file">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="SectionNavNextButton" Click="OnSectionNavNext"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Next match in file">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                    <Button Click="OnSectionNavDismiss"
                                            Width="24" Height="24" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Hide (reappears on next navigation)">
                                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid x:Name="PreviewEditorContainer" Grid.Row="1" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border x:Name="PreviewEditorPathBar" Grid.Row="0"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,6">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE7C3;" FontSize="14" Opacity="0.8" />
                                    <TextBlock x:Name="PreviewEditorPathText" FontSize="12"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border x:Name="PreviewEditorChunkPanel" Grid.Row="1" Visibility="Collapsed"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,6">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PreviewEditorChunkStatusText" FontSize="12" Opacity="0.75"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Button x:Name="LoadMorePreviewEditorChunkButton" Grid.Column="1"
                                            Click="OnLoadMorePreviewEditorChunk" FontSize="12" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                            <TextBlock Text="Load More" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <tcb:TextControlBox x:Name="PreviewEditor" Grid.Row="2" Visibility="Collapsed"
                                                FontFamily="Consolas, Cascadia Mono, Segoe UI, Segoe UI Symbol, Segoe UI Emoji"
                                                FontSize="13"
                                                ShowLineNumbers="True"
                                                ShowLineHighlighter="True"
                                                EnableSyntaxHighlighting="False"
                                                TextChanged="OnPreviewEditorTextChanged" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom status bar -->
        <Grid Grid.Row="5" Padding="20,8,20,10"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="420" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Bind ViewModel.FilesPerSecondText, Mode=OneWay}" Opacity="0.6" FontSize="12" FontFamily="Consolas" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Opacity="0.8" FontSize="12" />
            <Polyline x:Name="ThroughputSparkline" Grid.Column="2" Stroke="CornflowerBlue" StrokeThickness="1.2"
                      VerticalAlignment="Center" HorizontalAlignment="Stretch" Height="20" Opacity="0.7" />
            <TextBlock Grid.Column="3" FontSize="12" Opacity="0.6" x:Name="SkipCountBlock"
                       Tapped="OnSkipCountTapped" PointerEntered="OnSkipCountPointerEntered"
                       PointerExited="OnSkipCountPointerExited">
                <Run Text="Skipped: " />
                <Run Text="{x:Bind ViewModel.FilesSkipped, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Grid.Column="4" Foreground="DarkOrange" FontSize="12"
                       Visibility="{x:Bind ViewModel.Truncated, Mode=OneWay}"
                       Text="Results truncated — refine your query" />
            <Button x:Name="CollapseChevron" Grid.Column="5" Click="OnToggleResultsPane"
                    Background="Transparent" BorderThickness="0" Padding="6,2"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Collapse/expand results pane">
                <FontIcon x:Name="CollapseChevronIcon" FontFamily="{StaticResource SymbolThemeFontFamily}"
                          Glyph="&#xE70D;" FontSize="12" />
            </Button>
        </Grid>

        <!-- Skip breakdown overlay — floats above status bar, toggled by skip-count click -->
        <Border x:Name="SkipBreakdownOverlay"
                Grid.Row="4"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,8"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Canvas.ZIndex="100"
                Translation="0,0,32">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <TextBlock Text="{x:Bind ViewModel.SkipTooltip, Mode=OneWay}"
                       FontFamily="Consolas" FontSize="12"
                       IsTextSelectionEnabled="True" />
        </Border>

    </Grid>
</Window>
