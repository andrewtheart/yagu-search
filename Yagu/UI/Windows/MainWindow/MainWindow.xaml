<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Yagu.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Yagu"
    xmlns:vm="using:Yagu.ViewModels"
    xmlns:models="using:Yagu.Models"
    xmlns:tcb="using:TextControlBoxNS"
    Title="Yagu - Yet Another Grep Utility">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

          <Grid x:Name="RootGrid" AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop"
              SizeChanged="OnRootGridSizeChanged"
              PreviewKeyDown="OnRootGridPreviewKeyDown">
                <Grid.Resources>
        <DataTemplate x:Key="ResultGroupHeaderTemplate" x:DataType="models:ResultGroupHeaderRow">
            <Button Click="OnResultGroupHeaderClicked"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,8,4,2"
                    MinHeight="0">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,7"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ChevronGlyph, Mode=OneWay}"
                                  FontSize="11"
                                  Width="16"
                                  VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Title}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{ThemeResource SystemAccentColor}" />
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind SummaryText}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="FileGroupResultTemplate" x:DataType="models:FileGroup">
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}" Expanding="OnFileGroupExpanding" Collapsed="OnFileGroupCollapsed">
                <Expander.Header>
                    <Grid PointerPressed="OnFileGroupHeaderPointerPressed" PointerReleased="OnFileGroupHeaderPointerReleased" DoubleTapped="OnFileGroupHeaderDoubleTapped" Tag="{x:Bind FilePath}" Background="Transparent">
                        <Grid.ContextFlyout>
                            <MenuFlyout Opening="OnFileHeaderContextMenuOpening">
                                <MenuFlyoutItem Text="Preview" Click="OnPreviewSingleFile" Tag="{x:Bind FilePath}">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Preview all selected" Click="OnPreviewSelectedFiles" Tag="{x:Bind FilePath}">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Copy Full Path" Click="OnCopyFileGroupPath" Tag="{x:Bind FilePath}">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Copy Selected File Paths" Click="OnCopySelectedFilePaths">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Copy Selected Files With Content" Click="OnCopySelectedFilesWithContent">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Save Selected File Paths…" Click="OnSaveSelectedFilePaths">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Save Selected Files With Content…" Click="OnSaveSelectedFilesWithContent">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="320" MinWidth="0" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox AutomationProperties.AutomationId="FileGroupCheckBox"
                                  IsThreeState="False"
                                  IsChecked="{x:Bind AllSelected, Mode=OneWay}" MinWidth="32" MinHeight="0" Padding="0" VerticalAlignment="Center"
                                  Click="OnFileGroupCheckBoxClicked" />
                        <Border Grid.Column="1" Background="#1A6B5A" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" Margin="0,0,10,0" MinWidth="105"
                            Visibility="{x:Bind HasContentMatches, Mode=OneWay}">
                            <TextBlock VerticalAlignment="Center" HorizontalTextAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#B0E0D0">
                                <Run Text="{x:Bind MatchCount}" /><Run Text=" matches" />
                            </TextBlock>
                        </Border>
                        <StackPanel Grid.Column="2" MinWidth="0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind FileName}"
                                       ToolTipService.ToolTip="{x:Bind FileName}"
                                       FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind DirectoryName}" Tag="CompactDir"
                                       ToolTipService.ToolTip="{x:Bind DirectoryName}"
                                       FontSize="13" Opacity="0.55" TextTrimming="CharacterEllipsis"
                                       Visibility="Collapsed" />
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                <TextBlock Opacity="0.45" FontSize="11">
                                    <Run Text="Modified:" /><Run Text=" " /><Run Text="{x:Bind FormattedDate, Mode=OneWay}" /><Run Text=" | Size:" /><Run Text=" " /><Run Text="{x:Bind FormattedSize, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="{x:Bind DirectoryName}" Tag="WideDir"
                                   ToolTipService.ToolTip="{x:Bind DirectoryName}"
                                   Opacity="0.45" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   HorizontalAlignment="Left" Margin="12,0,4,0" />
                        <Button Grid.Column="4" Click="OnShowFileGroupInExplorer" Tag="{x:Bind FilePath}"
                                Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center" Margin="4,0,0,0"
                                ToolTipService.ToolTip="Open containing folder in Explorer">
                            <FontIcon Glyph="&#xED25;" FontSize="12" />
                        </Button>
                    </Grid>
                </Expander.Header>
                <StackPanel>
                    <ItemsControl ItemsSource="{x:Bind VisibleResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SearchResult">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{x:Bind NumberedBefore, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:ContextLine">
                                                <Grid ColumnSpacing="3" Padding="4,0,8,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{x:Bind LineNum}" FontFamily="Consolas" FontSize="11" Opacity="0.45"
                                                               HorizontalAlignment="Right" Margin="0,0,6,0" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Text}" FontFamily="Consolas" FontSize="11" Opacity="0.45"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid Padding="0,2,8,2" ColumnSpacing="3" Tapped="OnMatchLineTapped" Background="Transparent">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Copy Selected Lines" Click="OnCopySelectedLines">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Export Selected to File…" Click="OnExportSelectedLines">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Copy This Line" Click="OnCopySingleLine" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                      Click="OnMatchLineCheckBoxClicked"
                                                      MinWidth="34" MinHeight="22" Padding="5,1" Margin="4,0,2,0"
                                                      CornerRadius="4"
                                                      VerticalAlignment="Center"
                                                      HorizontalContentAlignment="Center">
                                            <TextBlock Text="{x:Bind LineNumber}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </ToggleButton>
                                        <RichTextBlock Grid.Column="1" TextTrimming="CharacterEllipsis" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="False" Loaded="OnMatchLineLoaded" VerticalAlignment="Center" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{x:Bind NumberedAfter, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:ContextLine">
                                                <Grid ColumnSpacing="3" Padding="4,0,8,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{x:Bind LineNum}" FontFamily="Consolas" FontSize="11" Opacity="0.45"
                                                               HorizontalAlignment="Right" Margin="0,0,6,0" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Text}" FontFamily="Consolas" FontSize="11" Opacity="0.45"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <HyperlinkButton Content="{x:Bind ShowMoreText, Mode=OneWay}"
                                     Visibility="{x:Bind HasMore, Mode=OneWay}"
                                     Click="OnShowMoreClicked"
                                     Tapped="OnShowMoreTapped"
                                     Padding="4,4,0,2" FontSize="12" />
                </StackPanel>
            </Expander>
        </DataTemplate>

        <local:ResultListItemTemplateSelector x:Key="ResultListItemTemplateSelector"
                                             GroupHeaderTemplate="{StaticResource ResultGroupHeaderTemplate}"
                                             FileGroupTemplate="{StaticResource FileGroupResultTemplate}" />
                </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="Auto" />  <!-- Custom title bar -->
            <RowDefinition Height="Auto" />  <!-- Admin banner -->
            <RowDefinition Height="Auto" />  <!-- Search card -->
            <RowDefinition x:Name="ProgressRow" Height="Auto" />  <!-- Status / progress -->
            <RowDefinition x:Name="SplitPaneRow" Height="*" />     <!-- Split pane -->
            <RowDefinition x:Name="TerminalRow" Height="0" />      <!-- Embedded terminal -->
            <RowDefinition x:Name="StatusBarRow" Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0,148,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE721;" FontSize="16" />
                <TextBlock x:Name="AppTitleText" Text="Yagu - Yet Another Grep Utility" Style="{ThemeResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <StackPanel x:Name="TitleBarActions" Grid.Row="0" Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" HorizontalAlignment="Right"
                    Margin="0,0,156,0" Canvas.ZIndex="100">
            <Button x:Name="PinButton" Click="OnPinToggle" VerticalAlignment="Center"
                    Width="36" Height="32" MinWidth="0" Padding="0"
                    Background="Transparent" BorderThickness="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    ToolTipService.ToolTip="Minimize to system tray when window loses focus">
                <FontIcon x:Name="PinIcon" Glyph="&#xE77A;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
            <Button Click="OnOpenCredits" VerticalAlignment="Center"
                    Width="36" Height="32" MinWidth="0" Padding="0"
                    Background="Transparent" BorderThickness="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    ToolTipService.ToolTip="Help">
                <FontIcon Glyph="&#xE897;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
            <Button Click="OnOpenSettings" VerticalAlignment="Center"
                    Width="36" Height="32" MinWidth="0" Padding="0"
                    Background="Transparent" BorderThickness="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
                <Button x:Name="CloseWindowButton" Click="OnCloseWindowClick" VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Width="36" Height="32" MinWidth="0" Padding="0"
                    Background="Transparent" BorderThickness="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    ToolTipService.ToolTip="Close Yagu">
                <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
        </StackPanel>

        <!-- Admin elevation banner (hidden when running elevated) -->
        <Border x:Name="AdminBanner" Grid.Row="1" Visibility="Collapsed"
                Background="#332000" Padding="10,4,10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Warning icon + text -->
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FFD54F" VerticalAlignment="Center" />
                    <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Run Text="Limited access" />
                        <Run Text="  " />
                        <Run Text="Some files may not be readable without administrator privileges." FontWeight="Normal" />
                    </TextBlock>
                </StackPanel>
                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Left" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button Content="Learn more..." FontSize="12" Padding="6,1" Click="OnAdminLearnMore" />
                    <Button Content="Restart as Admin" FontSize="12" Padding="6,1" Click="OnRestartAsAdmin" />
                    <Button Content="Don't show again" FontSize="12" Padding="6,1" Click="OnDontShowAdminWarningAgain" />
                </StackPanel>
                <!-- Close button -->
                <Button Grid.Column="2" Click="OnAdminBannerCloseClick"
                        Background="Transparent" BorderThickness="0" Padding="6,2"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>
        </Border>

        <!-- Search controls card -->
        <Border x:Name="SearchControlsBorder" Grid.Row="2" Margin="16,10,16,4" Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="10">
                <!-- Directory bar -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8B7;" FontSize="16" VerticalAlignment="Center" Opacity="0.7" />
                    <AutoSuggestBox
                        x:Name="DirectoryBox" Grid.Column="1"
                        PlaceholderText="Directory to search (e.g. D:\projects\myapp)"
                        Text="{x:Bind ViewModel.Directory, Mode=TwoWay}"
                        ItemsSource="{x:Bind ViewModel.DirectorySuggestions, Mode=OneWay}"
                        TextChanged="OnDirectoryTextChanged"
                        SuggestionChosen="OnDirectorySuggestionChosen"
                        QuerySubmitted="OnDirectoryQuerySubmitted" />
                    <Button x:Name="BrowseDirectoryButton" Grid.Column="2" Click="OnBrowseDirectory" ToolTipService.ToolTip="Browse for folder" Padding="8,6" MinWidth="0">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xED25;" FontSize="14" />
                            <TextBlock x:Name="BrowseDirectoryLabel" Text="Browse" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Search bar -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE721;" FontSize="16" VerticalAlignment="Center" Opacity="0.7" />
                    <Grid Grid.Column="1">
                        <AutoSuggestBox
                            x:Name="QueryBox"
                            PlaceholderText="Search query (Enter to run)"
                            Text="{x:Bind ViewModel.Query, Mode=TwoWay}"
                            ItemsSource="{x:Bind ViewModel.SearchHistory, Mode=OneWay}"
                            QuerySubmitted="OnQuerySubmitted"
                            TextChanged="OnQueryTextChanged"
                            LostFocus="OnQueryLostFocus"
                            KeyDown="OnQueryKeyDown" />
                        <!-- Inline toggle buttons for search options -->
                        <StackPanel x:Name="InlineSearchToggles"
                                    Orientation="Horizontal" Spacing="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,36,0">
                            <ToggleButton x:Name="CaseSensitiveToggle"
                                          IsChecked="{x:Bind ViewModel.CaseSensitive, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Match Case (Alt+C)"
                                          Padding="4,2" MinWidth="0" MinHeight="0"
                                          Width="28" Height="24" FontSize="12"
                                          VerticalAlignment="Center">
                                <TextBlock Text="Aa" FontSize="12" FontWeight="SemiBold" />
                            </ToggleButton>
                            <ToggleButton x:Name="RegexToggle"
                                          IsChecked="{x:Bind ViewModel.UseRegex, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Use Regular Expression (Alt+R)"
                                          Padding="4,2" MinWidth="0" MinHeight="0"
                                          Width="28" Height="24" FontSize="12"
                                          VerticalAlignment="Center">
                                <TextBlock Text=".*" FontSize="12" FontFamily="Consolas" />
                            </ToggleButton>
                            <ToggleButton x:Name="ExactMatchToggle"
                                          IsChecked="{x:Bind ViewModel.ExactMatch, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Exact Match — on: treat the whole query as one term. Off: split on spaces and match any term. (Alt+E)"
                                          Padding="4,2" MinWidth="0" MinHeight="0"
                                          Width="28" Height="24" FontSize="12"
                                          VerticalAlignment="Center">
                                <TextBlock Text="&quot;&quot;" FontSize="12" FontFamily="Consolas" />
                            </ToggleButton>
                        </StackPanel>
                        <Button x:Name="QueryClearButton"
                                Width="32" Height="32" MinWidth="0" Padding="0"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,4,0"
                                Background="Transparent" BorderThickness="0"
                                Visibility="{x:Bind ViewModel.HasQueryText, Mode=OneWay}"
                                Click="OnQueryClearClick"
                                ToolTipService.ToolTip="Clear query">
                            <FontIcon Glyph="&#xE894;" FontSize="12" />
                        </Button>
                    </Grid>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="SearchCardLoadSessionButton"
                                Click="OnLoadSession"
                                Width="32"
                                Height="32"
                                Padding="0"
                                MinWidth="0"
                                IsEnabled="{x:Bind ViewModel.IsSessionIdle, Mode=OneWay}"
                                ToolTipService.ToolTip="Load a previously saved .yagu-session file">
                            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        </Button>
                        <Button x:Name="SearchCancelButton" Click="OnSearchCancelClick" Style="{ThemeResource AccentButtonStyle}" Padding="12,6" MinWidth="0"
                                ToolTipService.ToolTip="Search (F5)">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="F5" />
                            </Button.KeyboardAccelerators>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="SearchCancelIcon" Glyph="&#xE721;" FontSize="14" />
                                <TextBlock x:Name="SearchCancelLabel" Text="Search" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Advanced options (collapsed by default) -->
                <Expander x:Name="AdvancedOptionsExpander"
                          IsExpanded="False" HorizontalAlignment="Left"
                          HorizontalContentAlignment="Stretch" Padding="0"
                          MinHeight="0" FontSize="12"
                          Expanding="OnAdvancedOptionsExpanding"
                          Collapsed="OnAdvancedOptionsCollapsed">
                    <Expander.Header>
                        <TextBlock Text="Advanced Options" VerticalAlignment="Center" />
                    </Expander.Header>
                        <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="24,12,12,12">
                    <Grid>
                        <Button x:Name="GenerateCliCommandButton"
                                Click="OnGenerateCliCommandClick"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                MinWidth="0" Padding="8,5"
                                Canvas.ZIndex="20"
                                ToolTipService.ToolTip="Generate an equivalent command-line search">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE756;" FontSize="11" />
                                <TextBlock Text="Generate CLI command" FontSize="11" />
                            </StackPanel>
                        </Button>
                    <StackPanel Spacing="10">
                        <!-- Search behavior -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Search mode" VerticalAlignment="Center" Opacity="0.7" Width="88" FontWeight="SemiBold" />
                            <ComboBox SelectedIndex="{x:Bind ViewModel.SearchModeIndex, Mode=TwoWay}" VerticalAlignment="Center">
                                <ComboBoxItem Content="Content + Names"
                                              ToolTipService.ToolTip="Search file contents and match file names against the query" />
                                <ComboBoxItem Content="Content only"
                                              ToolTipService.ToolTip="Search inside file contents only; ignore file names" />
                                <ComboBoxItem Content="File names only"
                                              ToolTipService.ToolTip="Match file names against the query without reading file contents" />
                                <ComboBoxItem Content="File name, then content"
                                              ToolTipService.ToolTip="First filter by file name, then search contents of matching files" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Path filters -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Path filters" Opacity="0.7"
                                       FontWeight="SemiBold" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid RowSpacing="4" ColumnSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#0078D4" CornerRadius="8" Padding="8,2"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Files to include. In Glob mode, use extensions, globs, or path segments. In Regex mode, match the normalized full path.">
                                        <TextBlock Text="Include" FontSize="11" Foreground="White"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <ComboBox Grid.Column="2"
                                              SelectedIndex="{x:Bind ViewModel.IncludeFilterModeIndex, Mode=TwoWay}"
                                              Width="88" Height="30" MinWidth="0" Padding="8,0"
                                              FontSize="12" VerticalAlignment="Center"
                                              ToolTipService.ToolTip="Include filter mode">
                                        <x:String>Glob</x:String>
                                        <x:String>Regex</x:String>
                                    </ComboBox>
                                    <TextBox x:Name="IncludeFilterBox" Grid.Row="1" Grid.ColumnSpan="3"
                                             PlaceholderText="{x:Bind ViewModel.IncludeFilterPlaceholder, Mode=OneWay}"
                                             Text="{x:Bind ViewModel.IncludeGlobs, Mode=TwoWay}"
                                             PlaceholderForeground="{ThemeResource TextFillColorPrimaryBrush}"
                                             Padding="8,4" FontStyle="Italic"
                                             TextChanged="OnFilterBoxTextChanged"
                                             GotFocus="OnFilterBoxGotFocus"
                                             LostFocus="OnFilterBoxLostFocus" />
                                </Grid>
                                <Grid Grid.Column="1" RowSpacing="4" ColumnSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#0078D4" CornerRadius="8" Padding="8,2"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Files to exclude. In Glob mode, use extensions, globs, or path segments. In Regex mode, match the normalized full path.">
                                        <TextBlock Text="Exclude" FontSize="11" Foreground="White"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <ComboBox Grid.Column="2"
                                              SelectedIndex="{x:Bind ViewModel.ExcludeFilterModeIndex, Mode=TwoWay}"
                                              Width="88" Height="30" MinWidth="0" Padding="8,0"
                                              FontSize="12" VerticalAlignment="Center"
                                              ToolTipService.ToolTip="Exclude filter mode">
                                        <x:String>Glob</x:String>
                                        <x:String>Regex</x:String>
                                    </ComboBox>
                                    <TextBox x:Name="ExcludeFilterBox" Grid.Row="1" Grid.ColumnSpan="3"
                                             PlaceholderText="{x:Bind ViewModel.ExcludeFilterPlaceholder, Mode=OneWay}"
                                             Text="{x:Bind ViewModel.ExcludeGlobs, Mode=TwoWay}"
                                             Padding="8,4" FontStyle="Italic"
                                             TextChanged="OnFilterBoxTextChanged"
                                             GotFocus="OnFilterBoxGotFocus"
                                             LostFocus="OnFilterBoxLostFocus" />
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <!-- File type filters -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="File type filters" Opacity="0.7"
                                       VerticalAlignment="Center" Width="88" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <ToggleSwitch x:Name="ObeyGitignoreCheckBox" OnContent="Obey .gitignore" OffContent="Obey .gitignore"
                                              IsOn="{x:Bind ViewModel.ObeyGitignore, Mode=TwoWay}" MinWidth="0"
                                              Toggled="OnObeyGitignoreToggled" />
                                <FontIcon Glyph="&#xE7BA;" FontSize="12" VerticalAlignment="Center"
                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                          ToolTipService.ToolTip="Enabling this decreases search performance due to extra .gitignore processing on every folder encountered during the scan." />
                            </StackPanel>
                            <DropDownButton Content="{x:Bind ViewModel.SkipExtensionsSummary, Mode=OneWay}"
                                            VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="Extensions to skip during search">
                                <DropDownButton.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <StackPanel Width="320" Spacing="2">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Skip Extensions" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <HyperlinkButton Grid.Column="1" Content="All" Click="OnSkipExtSelectAll" Padding="4,2" />
                                                <HyperlinkButton Grid.Column="2" Content="None" Click="OnSkipExtSelectNone" Padding="4,2" />
                                            </Grid>
                                            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                                <ItemsRepeater x:Name="SkipExtRepeater"
                                                               ItemsSource="{x:Bind ViewModel.SkipExtensionItems, Mode=OneWay}">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="0" />
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SkipExtensionItem">
                                                            <CheckBox IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                      MinWidth="0" MinHeight="0" Padding="6,2"
                                                                      Checked="OnSkipExtToggled" Unchecked="OnSkipExtToggled">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{x:Bind Extension}" FontFamily="Consolas" Width="50" />
                                                                    <TextBlock Text="{x:Bind Category}" Opacity="0.5" FontSize="11" />
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>

                        <!-- Content options -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Content options" Opacity="0.7"
                                       VerticalAlignment="Center" Width="88" FontWeight="SemiBold" />
                            <ToggleSwitch OnContent="Search binary" OffContent="Search binary"
                                          IsOn="{x:Bind ViewModel.SearchBinary, Mode=TwoWay}"
                                          VerticalAlignment="Center" MinWidth="0" />
                            <DropDownButton Content="{x:Bind ViewModel.BinaryExtensionsSummary, Mode=OneWay}"
                                            Visibility="{x:Bind ViewModel.BinaryExtensionsVisibility, Mode=OneWay}"
                                            VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="Known compiled binary/build artifact extensions to skip even when binary search is enabled">
                                <DropDownButton.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <StackPanel Width="320" Spacing="2">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Binary Extensions" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <HyperlinkButton Grid.Column="1" Content="All" Click="OnBinaryExtSelectAll" Padding="4,2" />
                                                <HyperlinkButton Grid.Column="2" Content="None" Click="OnBinaryExtSelectNone" Padding="4,2" />
                                            </Grid>
                                            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                                <ItemsRepeater x:Name="BinaryExtRepeater"
                                                               ItemsSource="{x:Bind ViewModel.BinaryExtensionItems, Mode=OneWay}">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="0" />
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SkipExtensionItem">
                                                            <CheckBox IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                      MinWidth="0" MinHeight="0" Padding="6,2"
                                                                      Checked="OnBinaryExtToggled" Unchecked="OnBinaryExtToggled">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{x:Bind Extension}" FontFamily="Consolas" Width="50" />
                                                                    <TextBlock Text="{x:Bind Category}" Opacity="0.5" FontSize="11" />
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <ToggleSwitch OnContent="Search archives" OffContent="Search archives"
                                              IsOn="{x:Bind ViewModel.SearchInsideArchives, Mode=TwoWay}"
                                              MinWidth="0" />
                                <FontIcon Glyph="&#xE7BA;" FontSize="12" VerticalAlignment="Center"
                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                          ToolTipService.ToolTip="Enabling this decreases search performance — archives must be decompressed and scanned individually. Only enable if you expect results inside ZIP files." />
                            </StackPanel>
                            <DropDownButton Content="{x:Bind ViewModel.ArchiveExtensionsSummary, Mode=OneWay}"
                                            Visibility="{x:Bind ViewModel.ArchiveExtensionsVisibility, Mode=OneWay}"
                                            VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="ZIP-like extensions to bypass from skip list when archive search is on">
                                <DropDownButton.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <StackPanel Width="320" Spacing="2">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Archive Extensions" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <HyperlinkButton Grid.Column="1" Content="All" Click="OnArchiveExtSelectAll" Padding="4,2" />
                                                <HyperlinkButton Grid.Column="2" Content="None" Click="OnArchiveExtSelectNone" Padding="4,2" />
                                            </Grid>
                                            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                                <ItemsRepeater x:Name="ArchiveExtRepeater"
                                                               ItemsSource="{x:Bind ViewModel.ArchiveExtensionItems, Mode=OneWay}">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="0" />
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SkipExtensionItem">
                                                            <CheckBox IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                      MinWidth="0" MinHeight="0" Padding="6,2"
                                                                      Checked="OnArchiveExtToggled" Unchecked="OnArchiveExtToggled">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{x:Bind Extension}" FontFamily="Consolas" Width="80" />
                                                                    <TextBlock Text="{x:Bind Category}" Opacity="0.5" FontSize="11" />
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>

                        <!-- Size & date constraints -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Property filters" Opacity="0.7"
                                       FontWeight="SemiBold" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Min MB" FontSize="11" Opacity="0.75" />
                                    <NumberBox Value="{x:Bind ViewModel.MinFileSizeMB, Mode=TwoWay}"
                                               Minimum="0"
                                               SpinButtonPlacementMode="Hidden"
                                               ToolTipService.ToolTip="Minimum file size in MB. Leave blank for no lower limit." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Max MB" FontSize="11" Opacity="0.75" />
                                    <NumberBox Value="{x:Bind ViewModel.MaxFileSizeMB, Mode=TwoWay}"
                                               Minimum="0"
                                               SpinButtonPlacementMode="Hidden"
                                               ToolTipService.ToolTip="Maximum file size in MB. Leave blank for no upper limit." />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Created Date" FontSize="11" Opacity="0.75" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker Date="{x:Bind ViewModel.CreatedAfterDate, Mode=TwoWay}"
                                                            PlaceholderText="From" HorizontalAlignment="Stretch"
                                                            ToolTipService.ToolTip="Only include files created on or after this date." />
                                        <CalendarDatePicker Grid.Column="1"
                                                            Date="{x:Bind ViewModel.CreatedBeforeDate, Mode=TwoWay}"
                                                            PlaceholderText="To" HorizontalAlignment="Stretch"
                                                            ToolTipService.ToolTip="Only include files created on or before this date." />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Modified Date" FontSize="11" Opacity="0.75" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker Date="{x:Bind ViewModel.ModifiedAfterDate, Mode=TwoWay}"
                                                            PlaceholderText="From" HorizontalAlignment="Stretch"
                                                            ToolTipService.ToolTip="Only include files modified on or after this date." />
                                        <CalendarDatePicker Grid.Column="1"
                                                            Date="{x:Bind ViewModel.ModifiedBeforeDate, Mode=TwoWay}"
                                                            PlaceholderText="To" HorizontalAlignment="Stretch"
                                                            ToolTipService.ToolTip="Only include files modified on or before this date." />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <!-- Max search depth -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <TextBlock Text="Max depth" Opacity="0.7"
                                       VerticalAlignment="Center" Width="88" FontWeight="SemiBold" />
                            <NumberBox Value="{x:Bind ViewModel.MaxSearchDepth, Mode=TwoWay}"
                                       Minimum="0" Width="90"
                                       SpinButtonPlacementMode="Hidden"
                                       ToolTipService.ToolTip="Maximum subdirectory depth for the current search only (0 = unlimited)." />
                        </StackPanel>
                    </StackPanel>
                    </Grid>
                    </Border>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Status / progress -->
        <StackPanel x:Name="SearchStatusPanel" Grid.Row="3" Padding="16,2,16,2" Spacing="4">
            <ProgressBar
                Visibility="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                Maximum="{x:Bind ViewModel.TotalFiles, Mode=OneWay}"
                Value="{x:Bind ViewModel.FilesScanned, Mode=OneWay}"
                IsIndeterminate="False" CornerRadius="3" Height="6"
                ToolTipService.ToolTip="{x:Bind ViewModel.ProgressTooltip, Mode=OneWay}" />
            <Grid Visibility="{x:Bind ViewModel.IsSessionBusy, Mode=OneWay}" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0"
                             Minimum="0" Maximum="100"
                             Value="{x:Bind ViewModel.SessionProgressPercent, Mode=OneWay}"
                             IsIndeterminate="False" CornerRadius="3" Height="6"
                             ToolTipService.ToolTip="{x:Bind ViewModel.SessionProgressText, Mode=OneWay}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Text="{x:Bind ViewModel.SessionProgressText, Mode=OneWay}" />
            </Grid>
            <TextBlock Foreground="OrangeRed"
                       Visibility="{x:Bind ViewModel.HasFallbackReason, Mode=OneWay}"
                       Text="{x:Bind ViewModel.FallbackReason, Mode=OneWay}" />
            <TextBlock Foreground="Red"
                       Visibility="{x:Bind ViewModel.HasErrorText, Mode=OneWay}"
                       Text="{x:Bind ViewModel.ErrorText, Mode=OneWay}" />
        </StackPanel>

        <!-- Split pane: results + preview -->
          <Grid x:Name="SplitPaneGrid" Grid.Row="4" Margin="16,2,16,4"
              SizeChanged="OnTopExpandedPreviewLayoutSourceSizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ResultsColumn" Width="*" MinWidth="200" />
                <ColumnDefinition x:Name="SplitterColumn" Width="0" />
                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Results panel card -->
                <Border x:Name="ResultsPanelBorder" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    SizeChanged="OnTopExpandedPreviewLayoutSourceSizeChanged"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="12,8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                        <DropDownButton Height="30" VerticalAlignment="Center" FontSize="12" ToolTipService.ToolTip="Sort results">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8CB;" FontSize="12" />
                                <TextBlock Text="Sort" />
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <Flyout x:Name="SortFlyout" Placement="BottomEdgeAlignedLeft" Opening="OnSortFlyoutOpening">
                                    <StackPanel MinWidth="154" Padding="8,6" Spacing="2">
                                        <Button Content="None" Click="OnSortNone"
                                                MinHeight="32" Padding="8,0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left" />
                                        <Grid MinHeight="32" ColumnSpacing="10" Padding="8,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="# Matches" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                <Button x:Name="SortMatchesAscButton" Click="OnSortMatchesAsc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort # Matches ascending">
                                                    <FontIcon Glyph="&#xE74A;" FontSize="11" />
                                                </Button>
                                                <Button x:Name="SortMatchesDescButton" Click="OnSortMatchesDesc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort # Matches descending">
                                                    <FontIcon Glyph="&#xE74B;" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <Grid MinHeight="32" ColumnSpacing="10" Padding="8,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Date Modified" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                <Button x:Name="SortDateModifiedAscButton" Click="OnSortDateModifiedAsc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort Date Modified ascending">
                                                    <FontIcon Glyph="&#xE74A;" FontSize="11" />
                                                </Button>
                                                <Button x:Name="SortDateModifiedDescButton" Click="OnSortDateModifiedDesc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort Date Modified descending">
                                                    <FontIcon Glyph="&#xE74B;" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <Grid MinHeight="32" ColumnSpacing="10" Padding="8,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="File Size" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                <Button x:Name="SortFileSizeAscButton" Click="OnSortFileSizeAsc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort File Size ascending">
                                                    <FontIcon Glyph="&#xE74A;" FontSize="11" />
                                                </Button>
                                                <Button x:Name="SortFileSizeDescButton" Click="OnSortFileSizeDesc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort File Size descending">
                                                    <FontIcon Glyph="&#xE74B;" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <Grid MinHeight="32" ColumnSpacing="10" Padding="8,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="File Name" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                <Button x:Name="SortFileNameAscButton" Click="OnSortFileNameAsc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort File Name ascending">
                                                    <FontIcon Glyph="&#xE74A;" FontSize="11" />
                                                </Button>
                                                <Button x:Name="SortFileNameDescButton" Click="OnSortFileNameDesc"
                                                        Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        ToolTipService.ToolTip="Sort File Name descending">
                                                    <FontIcon Glyph="&#xE74B;" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <DropDownButton Height="30" VerticalAlignment="Center" FontSize="12" ToolTipService.ToolTip="Group results by…">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8FD;" FontSize="12" />
                                <TextBlock Text="Group" />
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                    <MenuFlyoutItem Text="None" Click="OnGroupModeNone" />
                                    <MenuFlyoutSubItem Text="Folder">
                                        <MenuFlyoutItem Text="A-Z" Click="OnGroupFolderAZ" />
                                        <MenuFlyoutItem Text="Z-A" Click="OnGroupFolderZA" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSubItem Text="Date range (Modified)">
                                        <MenuFlyoutItem Text="Recent first" Click="OnGroupDateModifiedRecent" />
                                        <MenuFlyoutItem Text="Older first" Click="OnGroupDateModifiedOlder" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSubItem Text="Date range (Created)">
                                        <MenuFlyoutItem Text="Recent first" Click="OnGroupDateCreatedRecent" />
                                        <MenuFlyoutItem Text="Older first" Click="OnGroupDateCreatedOlder" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSubItem Text="Date range (Modified + Created)">
                                        <MenuFlyoutItem Text="Recent first" Click="OnGroupDateModCreatedRecent" />
                                        <MenuFlyoutItem Text="Older first" Click="OnGroupDateModCreatedOlder" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSubItem Text="Extension">
                                        <MenuFlyoutItem Text="A-Z" Click="OnGroupExtensionAZ" />
                                        <MenuFlyoutItem Text="Z-A" Click="OnGroupExtensionZA" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSubItem Text="File size">
                                        <MenuFlyoutItem Text="Small to large" Click="OnGroupFileSizeSmallLarge" />
                                        <MenuFlyoutItem Text="Large to small" Click="OnGroupFileSizeLargeSmall" />
                                    </MenuFlyoutSubItem>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <DropDownButton Height="30" VerticalAlignment="Center" FontSize="12" ToolTipService.ToolTip="Filter results">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE71C;" FontSize="12" />
                                <TextBlock Text="Filter" />
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedLeft" Opening="OnFilterFlyoutOpening">
                                    <MenuFlyoutSubItem Text="By date">
                                        <MenuFlyoutItem Text="Any date" Click="OnDateFilterNone" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Last day" Click="OnDateFilterPastDay" />
                                        <MenuFlyoutItem Text="Last week" Click="OnDateFilterPastWeek" />
                                        <MenuFlyoutItem Text="Last 2 weeks" Click="OnDateFilterPastTwoWeeks" />
                                        <MenuFlyoutItem Text="Last month" Click="OnDateFilterPastMonth" />
                                        <MenuFlyoutItem Text="Last 3 months" Click="OnDateFilterPastThreeMonths" />
                                        <MenuFlyoutItem Text="Last 6 months" Click="OnDateFilterPastSixMonths" />
                                        <MenuFlyoutItem Text="Last 9 months" Click="OnDateFilterPastNineMonths" />
                                        <MenuFlyoutItem Text="Last year" Click="OnDateFilterPastYear" />
                                        <MenuFlyoutItem Text="Last 2 years" Click="OnDateFilterPastTwoYears" />
                                        <MenuFlyoutItem Text="Last 3 years" Click="OnDateFilterPastThreeYears" />
                                        <MenuFlyoutItem Text="Last 5 years" Click="OnDateFilterPastFiveYears" />
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSubItem x:Name="ExtensionFilterSubMenu" Text="By extension" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <CheckBox x:Name="AutoScrollResultsCheckBox"
                                  Content="Auto-scroll"
                                  IsChecked="False"
                                  VerticalAlignment="Center"
                                  FontSize="12"
                                  MinWidth="0"
                                  MinHeight="0"
                                  Padding="4,0,0,0"
                                  Visibility="{x:Bind ViewModel.AutoScrollResultsCheckboxVisibility, Mode=OneWay}"
                                  Checked="OnAutoScrollResultsChanged"
                                  Unchecked="OnAutoScrollResultsChanged"
                                  ToolTipService.ToolTip="Follow new results as they arrive" />
                        <Button x:Name="ResultsOptionsButton"
                                Width="28" Height="28" MinWidth="0" MinHeight="0"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center" ToolTipService.ToolTip="Results options">
                            <FontIcon Glyph="&#xE700;" FontSize="12" />
                            <Button.Flyout>
                                <Flyout x:Name="ResultsOptionsFlyout" Placement="BottomEdgeAlignedRight">
                                    <StackPanel Width="220" Spacing="6" Padding="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="Context:" VerticalAlignment="Center" FontSize="12" Opacity="0.8" />
                                            <NumberBox Value="{x:Bind ViewModel.ContextLines, Mode=TwoWay}" Minimum="0" Maximum="20"
                                                       SpinButtonPlacementMode="Hidden" MinWidth="64" Width="64" FontSize="12"
                                                       ToolTipService.ToolTip="Context lines included with each search result" />
                                        </StackPanel>

                                        <Border Height="1" Margin="0,2" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                                        <Button Click="OnClearResults" Background="Transparent" BorderThickness="0"
                                                Padding="8,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                ToolTipService.ToolTip="Clear all results (Ctrl+Shift+Delete)">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                <TextBlock Text="Clear all results" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="SaveSessionButton" Click="OnSaveSession" Background="Transparent" BorderThickness="0"
                                                Padding="8,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                IsEnabled="{x:Bind ViewModel.IsSessionIdle, Mode=OneWay}"
                                                ToolTipService.ToolTip="Save current results to a .yagu-session file">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                                <TextBlock Text="Save session" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="LoadSessionButton" Click="OnLoadSession" Background="Transparent" BorderThickness="0"
                                                Padding="8,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                IsEnabled="{x:Bind ViewModel.IsSessionIdle, Mode=OneWay}"
                                                ToolTipService.ToolTip="Load a previously saved .yagu-session file">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                                                <TextBlock Text="Load session" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DegradedNoticeText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.MemoryPressureWarningVisibility, Mode=OneWay}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="12" Foreground="DarkOrange" Opacity="0.9" Margin="8,0,4,0" />
                        <Button x:Name="ExpandResultsButton" Grid.Column="2"
                                Click="OnExpandResultsPanel"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,4" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Expand file list / collapse preview">
                            <FontIcon x:Name="ExpandResultsIcon" Glyph="&#xE740;" FontSize="12" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="8,6" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="SelectAllFilesCheckBox"
                                  ToolTipService.ToolTip="Select / deselect all files"
                                  IsThreeState="False"
                                  IsChecked="False"
                                  MinWidth="32" MinHeight="0" Padding="0"
                                  VerticalAlignment="Center"
                                  Checked="OnSelectAllFilesChecked"
                                  Unchecked="OnSelectAllFilesUnchecked" />
                        <Grid Grid.Column="1">
                            <TextBox PlaceholderText="Filter files…"
                                     Text="{x:Bind ViewModel.FileNameFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="30,4,8,4" FontSize="12" />
                            <FontIcon Glyph="&#xE71C;" FontSize="12" Opacity="0.65"
                                      HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Margin="10,0,0,0" IsHitTestVisible="False" />
                        </Grid>
                    </Grid>

                    <ListView
                        x:Name="ResultsList"
                        Grid.Row="2"
                        SelectionMode="None"
                        ShowsScrollingPlaceholders="True"
                        IsItemClickEnabled="True"
                        ItemClick="OnResultItemClick"
                        DoubleTapped="OnResultDoubleTapped"
                        KeyDown="OnResultsListKeyDown"
                        PointerPressed="OnResultsListPointerPressed"
                        RightTapped="OnResultsListRightTapped"
                        ItemsSource="{x:Bind ViewModel.ResultRows, Mode=OneWay}"
                        ItemTemplateSelector="{StaticResource ResultListItemTemplateSelector}"
                        SizeChanged="OnResultsListSizeChanged"
                        ContainerContentChanging="OnResultsListContainerContentChanging"
                        Padding="4,0">
                        <ListView.ContextFlyout>
                            <MenuFlyout Opening="OnResultsContextMenuOpening">
                                <MenuFlyoutItem x:Name="CtxPreviewSingle" Text="Preview" Click="OnPreviewSingleFile">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="CtxPreviewSelected" Text="Preview all selected" Click="OnPreviewSelectedFiles">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem x:Name="CtxCopyPaths" Text="Copy File Path" Click="OnCopySelectedFilePaths">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="CtxCopyWithContent" Text="Copy File With Content" Click="OnCopySelectedFilesWithContent">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem x:Name="CtxSavePaths" Text="Save File Path…" Click="OnSaveSelectedFilePaths">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="CtxSaveWithContent" Text="Save File With Content…" Click="OnSaveSelectedFilesWithContent">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </ListView.ContextFlyout>
                    </ListView>

                    <Border x:Name="ResultsFileOverlay" Grid.Row="2"
                            Visibility="Collapsed"
                            VerticalAlignment="Top" HorizontalAlignment="Stretch"
                            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="0,0,0,1"
                            Padding="10,5"
                            Tapped="OnResultsFileOverlayTapped"
                            DoubleTapped="OnResultsFileOverlayDoubleTapped"
                            Canvas.ZIndex="30">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE7C3;" FontSize="13" Opacity="0.75"
                                      VerticalAlignment="Center" />
                            <TextBlock x:Name="ResultsFileOverlayFileName" Grid.Column="1"
                                       FontSize="12" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <Button x:Name="ResultsFileOverlayExplorerButton" Grid.Column="2"
                                    Click="OnShowFileGroupInExplorer"
                                    Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Open containing folder in Explorer">
                                <FontIcon Glyph="&#xED25;" FontSize="12" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="SplitterBorder" Grid.Column="1" Width="8" Background="Transparent"
                    Visibility="Collapsed"
                    PointerPressed="OnSplitterPressed"
                    PointerMoved="OnSplitterMoved"
                    PointerReleased="OnSplitterReleased"
                    PointerEntered="OnSplitterPointerEntered"
                    PointerExited="OnSplitterPointerExited">
                <!-- Grip dots indicating the splitter can be dragged -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="3" Opacity="0.4">
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="3" Height="3" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Preview panel card -->
                <Border x:Name="PreviewPanelBorder" Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    SizeChanged="OnTopExpandedPreviewLayoutSourceSizeChanged"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="PreviewHeaderBar" Padding="12,8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="PreviewToolbarContent" Orientation="Horizontal" Spacing="4" Visibility="Collapsed" HorizontalAlignment="Left">
                            <!-- File identity (icon + label hidden) -->
                            <FontIcon Glyph="&#xE7B3;" FontSize="12" VerticalAlignment="Center" Opacity="0.6" Visibility="Collapsed" />
                            <TextBlock x:Name="PreviewFileLabel" VerticalAlignment="Center" FontSize="12" Opacity="0.7"
                                       TextTrimming="CharacterEllipsis" MaxWidth="300" Visibility="Collapsed" />

                            <!-- Primary actions (icon-only compact buttons) -->
                            <Button x:Name="FullFileButton" Click="OnShowFullFile" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Open the selected file in the full-file editor">
                                <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                            </Button>
                            <Button x:Name="CopyPreviewFilePathButton" Click="OnCopyPreviewFilePath" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Copy the current preview file path">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                            </Button>
                            <Button x:Name="OpenInDefaultAppButton" Click="OnOpenInDefaultApp" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Open the current file with the default app">
                                <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                            </Button>
                            <Button x:Name="OpenInEditorButton" Click="OnOpenInEditor" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Open the current file in your configured external editor">
                                <FontIcon Glyph="&#xE70F;" FontSize="12" />
                            </Button>
                            <Button x:Name="ExpandAllSectionsButton" Click="OnExpandAllSections" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" Visibility="Collapsed" ToolTipService.ToolTip="Expand all preview sections">
                                <FontIcon Glyph="&#xE740;" FontSize="12" />
                            </Button>
                            <Button x:Name="ExportReportButton" Click="OnExportHtmlReport" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Export the current preview as a report">
                                <FontIcon Glyph="&#xE9F9;" FontSize="12" />
                            </Button>

                            <AppBarSeparator x:Name="PreviewToolbarSeparator" />

                            <!-- View options -->
                            <DropDownButton x:Name="LayoutDropDown" Content="Layout" VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="Choose how selected files are laid out in the preview">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <ToggleMenuFlyoutItem x:Name="LayoutConcatenated" Text="Concatenated" Click="OnLayoutOptionClicked" />
                                        <ToggleMenuFlyoutItem x:Name="LayoutMultiHighlight" Text="Multi-highlight" Click="OnLayoutOptionClicked" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <Button x:Name="WordWrapDropDown" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                          Padding="0"
                                          ToolTipService.ToolTip="Choose word wrap mode for the preview and editor">
                                <FontIcon Glyph="&#xE8B3;" FontSize="12" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <ToggleMenuFlyoutItem x:Name="WrapModeWrap" Text="Word wrap" Click="OnWrapModeOptionClicked" />
                                        <ToggleMenuFlyoutItem x:Name="WrapModeNone" Text="No wrap" Click="OnWrapModeOptionClicked" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button x:Name="FindReplaceButton" Click="OnOpenFindReplaceBar" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Find or replace text in the preview/editor">
                                <FontIcon Glyph="&#xE721;" FontSize="12" />
                            </Button>
                            <StackPanel x:Name="PreviewContextPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Set how many context lines are shown around each preview match">
                                <TextBlock Text="Preview Context:" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.PreviewContextLines, Mode=TwoWay}" Minimum="0"
                                           SpinButtonPlacementMode="Compact" MinWidth="64" Width="64" FontSize="12"
                                           ToolTipService.ToolTip="Number of context lines shown around each match" />
                            </StackPanel>
                            <Button x:Name="ClearPreviewButton" Click="OnClearPreview" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                    Padding="0" ToolTipService.ToolTip="Clear the preview">
                                <FontIcon Glyph="&#xE894;" FontSize="12" />
                            </Button>

                        </StackPanel>
                        <StackPanel x:Name="MatchNavPanel" Grid.Column="1" Visibility="Collapsed"
                                    Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Border Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    BorderBrush="{ThemeResource SystemAccentColor}"
                                    BorderThickness="1" CornerRadius="6" Padding="6,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="MatchNavLabel" FontSize="11" Opacity="0.8"
                                               VerticalAlignment="Center" Margin="2,0"
                                               ToolTipService.ToolTip="Occurrences count every highlighted hit, including multiple hits on the same source line. The results list on the left is paged, so this occurrence may not be visible there until more rows are loaded." />
                                    <Button x:Name="PrevMatchButton" Click="OnPrevMatch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Previous occurrence">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="NextMatchButton" Click="OnNextMatch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Next occurrence">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button x:Name="ExpandPreviewButton" Grid.Column="2"
                                Click="OnExpandPreviewPanel"
                                Background="Transparent" BorderThickness="0"
                            Padding="6,4" VerticalAlignment="Center" Margin="6,0,0,0"
                                ToolTipService.ToolTip="Maximize preview / change preview layout">
                            <FontIcon x:Name="ExpandPreviewIcon" Glyph="&#xE740;" FontSize="12" />
                        </Button>
                    </Grid>
                    <Grid x:Name="PreviewContentHost" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Find / Replace bar -->
                        <Border x:Name="FindBar" Visibility="Collapsed" Grid.Row="0"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1" Padding="8,6">
                            <Grid HorizontalAlignment="Right">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4">
                                    <TextBox x:Name="FindTextBox" PlaceholderText="Find…" Width="220" FontSize="12"
                                             KeyDown="OnFindTextBoxKeyDown" TextChanged="OnFindTextBoxTextChanged"
                                             IsSpellCheckEnabled="False" IsTextPredictionEnabled="False" />
                                    <Button Click="OnFindPrevious" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button Click="OnFindNext" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                    <CheckBox x:Name="FindMatchCaseCheckBox" Content="Aa" FontSize="11" MinWidth="0" Padding="4,0"
                                              Unchecked="OnFindOptionChanged" Checked="OnFindOptionChanged" />
                                    <ToggleButton x:Name="FindReplaceToggle" Click="OnFindReplaceToggle" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0">
                                        <FontIcon Glyph="&#xE8AC;" FontSize="12" />
                                    </ToggleButton>
                                    <TextBlock x:Name="FindStatusText" VerticalAlignment="Center" FontSize="11" Opacity="0.6" Margin="4,0,0,0" />
                                    <Button Click="OnCloseFindBar" Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                                <StackPanel x:Name="ReplaceRow" Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0" Visibility="Collapsed">
                                    <TextBox x:Name="ReplaceTextBox" PlaceholderText="Replace…" Width="220" FontSize="12"
                                             KeyDown="OnReplaceTextBoxKeyDown"
                                             IsSpellCheckEnabled="False" IsTextPredictionEnabled="False" />
                                    <Button x:Name="ReplaceOneButton" Click="OnReplaceOne" FontSize="12" Padding="8,4">
                                        <TextBlock Text="Replace" />
                                    </Button>
                                    <Button x:Name="ReplaceAllButton" Click="OnReplaceAll" FontSize="12" Padding="8,4">
                                        <TextBlock Text="All" />
                                    </Button>
                                    <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,2" />
                                    <Button x:Name="ReplaceInFilesButton" Click="OnReplaceInAllFiles"
                                            FontSize="12" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8AC;" FontSize="12" />
                                            <TextBlock Text="All Files" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="PreviewScrollViewer" Grid.Row="1" Padding="16,12"
                                      HorizontalScrollMode="Enabled"
                                      HorizontalScrollBarVisibility="Visible"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel x:Name="PreviewMessagePanel">
                                    <RichTextBlock x:Name="PreviewBlock" FontFamily="Consolas" TextWrapping="NoWrap" />
                                    <Button x:Name="PreviewBackButton" Visibility="Collapsed"
                                            Click="OnPreviewBackClick" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE72B;" FontSize="12" />
                                            <TextBlock Text="Back to preview" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <StackPanel x:Name="PreviewSectionsPanel" Visibility="Collapsed" Spacing="8" />
                                <StackPanel x:Name="PreviewLoadingPanel" Visibility="Collapsed"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                                            Margin="0,48,0,0">
                                    <ProgressRing x:Name="PreviewLoadingRing" IsActive="False" Width="36" Height="36" />
                                    <TextBlock x:Name="PreviewLoadingText" Text="Loading preview…"
                                               HorizontalAlignment="Center" Opacity="0.7" FontSize="13" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <Grid x:Name="PreviewEmptyState" Grid.Row="1"
                              Visibility="Collapsed"
                              IsHitTestVisible="False"
                              Padding="24,0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Canvas.ZIndex="5">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="640"
                                        Spacing="8">
                                <TextBlock Text="Nothing to show"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="NoWrap" />
                                <TextBlock Text="Add files to this preview by selecting one or more files on the left panel, right clicking, and selecting the preview option."
                                           FontSize="13"
                                           Opacity="0.72"
                                           TextAlignment="Center"
                                           TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>

                        <!-- Sticky horizontal scrollbar for multi-section preview mode.
                             The per-section ScrollViewers host horizontal scrolling but their
                             native scrollbars are anchored to the bottom of section content
                             (often thousands of pixels below the viewport). This overlay bar
                             is wired in code-behind to the currently-active section's scroller
                             so horizontal overflow is reachable without arrow-keying blindly. -->
                        <ScrollBar x:Name="StickyHorizontalScrollBar" Grid.Row="1"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                                   Margin="16,0,16,2"
                                   Visibility="Collapsed"
                                   Canvas.ZIndex="30"
                                   Scroll="OnStickyHorizontalScrollBarScroll" />

                        <!-- Sticky file header: shown when the actual file expander header
                             of the section currently in view has scrolled out the top.
                             Content is built dynamically from BuildPreviewSectionHeader so
                             it mirrors the per-file action buttons (Show full file, Copy
                             path, Open, Edit, Show in Explorer, Dismiss). -->
                        <Border x:Name="StickyFileHeader" Grid.Row="1" Visibility="Collapsed"
                                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1"
                                Padding="12,6"
                                Tapped="StickyFileHeader_Tapped" />

                        <Canvas x:Name="ActiveMatchOverlay" Grid.Row="1"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Canvas.ZIndex="20"
                            IsHitTestVisible="False" Visibility="Collapsed">
                            <Border x:Name="ActiveMatchBand"
                                Canvas.ZIndex="20"
                                Height="18"
                                Background="#22FF6A00"
                                BorderBrush="#FFFF4500"
                                BorderThickness="4,0,0,0"
                                CornerRadius="3" />
                            <Border x:Name="ActiveMatchWordMarker"
                                Canvas.ZIndex="21"
                                Height="18"
                                MinWidth="12"
                                Background="#1AFF4500"
                                BorderBrush="#FFFF4500"
                                BorderThickness="0,0,0,2"
                                CornerRadius="2" />
                        </Canvas>

                            <Canvas x:Name="PreviewShowMoreTooltipOverlay" Grid.Row="1"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                Canvas.ZIndex="35"
                                IsHitTestVisible="True"
                                Visibility="Collapsed">
                                <Border x:Name="PreviewShowMoreTooltipBubble"
                                    Background="#B8181818"
                                    CornerRadius="4"
                                    Padding="7,4">
                                <StackPanel x:Name="PreviewShowMoreTooltipContent"
                                        Orientation="Horizontal"
                                        Spacing="6" />
                                </Border>
                            </Canvas>

                        <!-- Progress overlay for "Show all files" -->
                        <Grid x:Name="PreviewProgressOverlay" Grid.Row="1" Visibility="Collapsed">
                            <Border Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    Opacity="0.85" />
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <ProgressRing x:Name="PreviewProgressRing" IsActive="False" Width="40" Height="40" />
                                <TextBlock x:Name="PreviewProgressText" Text="Loading files…"
                                           HorizontalAlignment="Center" FontSize="14" />
                                <TextBlock x:Name="PreviewProgressPercent" Text="0%"
                                           HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <!-- Per-section match navigation overlay (file-level, stays visible during scroll) -->
                        <StackPanel x:Name="SectionNavOverlay" Grid.Row="1" Visibility="Collapsed"
                                    Orientation="Horizontal" Spacing="2"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="0,0,8,8" Opacity="0.75"
                                    PointerEntered="OnSectionNavPointerEntered"
                                    PointerExited="OnSectionNavPointerExited">
                            <Border Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    BorderBrush="{ThemeResource SystemAccentColor}"
                                    BorderThickness="1" CornerRadius="6" Padding="6,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="SectionNavLabel" FontSize="11" Opacity="0.8"
                                               VerticalAlignment="Center" Margin="2,0"
                                               ToolTipService.ToolTip="Current occurrence and total matches in the active preview file." />
                                    <Button x:Name="SectionPrevButton" Click="OnSectionNavPrev"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Previous occurrence in this file">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="SectionNavNextButton" Click="OnSectionNavNext"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="Next occurrence in this file">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                    <Button Click="OnSectionNavDismiss"
                                            Width="24" Height="24" MinWidth="0" MinHeight="0" Padding="0"
                                            CornerRadius="4">
                                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid x:Name="PreviewEditorContainer" Grid.Row="1" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border x:Name="PreviewEditorPathBar" Grid.Row="0"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,7"
                                    MinHeight="50">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE7C3;" FontSize="14" Opacity="0.8"
                                              VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="PreviewEditorPathText" FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Left">
                                            <TextBlock x:Name="PreviewEditorChunkStatusText" Visibility="Collapsed"
                                                       FontSize="11" Opacity="0.65"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel x:Name="PreviewEditorChunkPanel" Visibility="Collapsed"
                                                        Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="LoadMorePreviewEditorChunkButton"
                                                        Click="OnLoadMorePreviewEditorChunk" FontSize="11" Padding="6,2"
                                                        ToolTipService.ToolTip="Load the next chunk of this large file into the editor">
                                                    <TextBlock Text="Load More" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel x:Name="PreviewEditorToolbarPanel" Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button x:Name="EditorCopyPreviewFilePathButton" Click="OnCopyPreviewFilePath"
                                                Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                                ToolTipService.ToolTip="Copy the current editor file path">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                        </Button>
                                        <Button x:Name="EditorWordWrapDropDown" Width="28" Height="28" MinWidth="0" MinHeight="0"
                                                      Padding="0"
                                                      ToolTipService.ToolTip="Choose word wrap mode for the editor">
                                            <FontIcon Glyph="&#xE8B3;" FontSize="12" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <ToggleMenuFlyoutItem x:Name="EditorWrapModeWrap" Text="Word wrap" Click="OnWrapModeOptionClicked" />
                                                    <ToggleMenuFlyoutItem x:Name="EditorWrapModeNone" Text="No wrap" Click="OnWrapModeOptionClicked" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button x:Name="EditorFindReplaceButton" Click="OnOpenFindReplaceBar"
                                                Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                                                ToolTipService.ToolTip="Find or replace text in the editor">
                                            <FontIcon Glyph="&#xE721;" FontSize="12" />
                                        </Button>
                                    </StackPanel>
                                    <StackPanel x:Name="EditorButtonsPanel" Grid.Column="3" Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center" Visibility="Collapsed">
                                        <Button x:Name="SavePreviewEditButton" Click="OnSavePreviewEdit" FontSize="12" Padding="8,4"
                                                IsEnabled="False" ToolTipService.ToolTip="Save editor changes to the file">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                                <TextBlock Text="Save" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ClosePreviewEditButton" Click="OnClosePreviewEdit" FontSize="12" Padding="8,4"
                                                ToolTipService.ToolTip="Close the editor and return to preview">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE72B;" FontSize="12" />
                                                <TextBlock Text="Back" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                        <Button x:Name="PreviewEditorExpandButton" Grid.Column="4"
                                            Click="OnExpandPreviewPanel"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="6,4" VerticalAlignment="Center" Margin="2,0,0,0"
                                            ToolTipService.ToolTip="Maximize editor / change preview layout">
                                        <FontIcon x:Name="PreviewEditorExpandIcon" Glyph="&#xE740;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </Border>
                            <tcb:TextControlBox x:Name="PreviewEditor" Grid.Row="1" Visibility="Collapsed"
                                                FontFamily="Consolas, Cascadia Mono, Segoe UI, Segoe UI Symbol, Segoe UI Emoji"
                                                FontSize="13"
                                                ShowLineNumbers="True"
                                                ShowLineHighlighter="True"
                                                EnableSyntaxHighlighting="False"
                                                TextChanged="OnPreviewEditorTextChanged" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom status bar -->
        <Grid Grid.Row="6" Padding="20,8,20,10"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="420" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Bind ViewModel.FilesPerSecondText, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.StatsForNerdsVisibility, Mode=OneWay}"
                     Opacity="0.6" FontSize="12" FontFamily="Consolas" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Opacity="0.8" FontSize="12" FontFamily="Consolas" />
            <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" Height="20"
                Visibility="{x:Bind ViewModel.StatsForNerdsVisibility, Mode=OneWay}">
                <!-- Background utilization gauge -->
                <Rectangle x:Name="DiskGaugeBar" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                           Fill="CornflowerBlue" Opacity="0.18" Width="0" />
                <Polyline x:Name="ThroughputSparkline" Stroke="CornflowerBlue" StrokeThickness="1.2"
                          VerticalAlignment="Center" HorizontalAlignment="Stretch" Opacity="0.7" />
                <TextBlock x:Name="DiskGaugeLabel" VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontFamily="Consolas" FontSize="11" Opacity="0.75" Margin="0,0,6,0" />
            </Grid>
            <TextBlock Grid.Column="3" FontSize="12" Opacity="0.6" x:Name="SkipCountBlock"
                       FontFamily="Consolas" Width="140" TextAlignment="Right"
                       Tapped="OnSkipCountTapped" PointerEntered="OnSkipCountPointerEntered"
                       PointerExited="OnSkipCountPointerExited">
                <Run Text="Skipped: " />
                <Run Text="{x:Bind ViewModel.FilesSkipped, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Grid.Column="4" Foreground="DarkOrange" FontSize="12"
                       Visibility="{x:Bind ViewModel.Truncated, Mode=OneWay}"
                       Text="Results truncated — refine your query" />
            <Button x:Name="TerminalChevron" Grid.Column="5" Click="OnToggleTerminalPane"
                    Background="Transparent" BorderThickness="0" Padding="6,2"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Toggle embedded terminal">
                <FontIcon x:Name="TerminalChevronIcon" FontFamily="{StaticResource SymbolThemeFontFamily}"
                          Glyph="&#xE70D;" FontSize="12" />
            </Button>
        </Grid>

            <Button x:Name="PreSearchTerminalChevron"
                Grid.RowSpan="7"
                Click="OnToggleTerminalPane"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Width="36" Height="32" MinWidth="0" MinHeight="0"
                Padding="0"
                Margin="0,0,20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Canvas.ZIndex="210"
                ToolTipService.ToolTip="Toggle embedded terminal">
                <FontIcon x:Name="PreSearchTerminalChevronIcon"
                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                      Glyph="&#xE70D;" FontSize="12" />
            </Button>

        <!-- Generated CLI command overlay -->
        <Border x:Name="GeneratedCliCommandOverlay"
                Grid.RowSpan="7"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,92,24,0"
                MaxWidth="760"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10"
                Canvas.ZIndex="220"
                Translation="0,0,48">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CLI command"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Button x:Name="CopyGeneratedCliCommandButton" Grid.Column="1"
                            Click="OnCopyGeneratedCliCommandClick"
                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Copy command">
                        <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                    </Button>
                    <Button x:Name="SendGeneratedCliCommandToTerminalButton" Grid.Column="2"
                            Click="OnSendGeneratedCliCommandToTerminalClick"
                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Send command to terminal">
                        <FontIcon Glyph="&#xE756;" FontSize="12" />
                    </Button>
                    <Button x:Name="CloseGeneratedCliCommandOverlayButton" Grid.Column="3"
                            Click="OnCloseGeneratedCliCommandOverlayClick"
                            Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Close">
                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                    </Button>
                </Grid>
                <ToggleSwitch x:Name="IncludeSavedSettingCliOptionsToggle"
                              Grid.Row="1"
                              Header="Options already saved in settings"
                              IsOn="False"
                              OnContent="Include"
                              OffContent="Omit"
                              FontSize="12"
                              ToolTipService.ToolTip="Omit options that already match the current settings file to make the command shorter."
                              Toggled="OnGeneratedCliCommandSavedSettingOptionsToggled" />
                <Border x:Name="GeneratedCliCommandBubble"
                        Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,8">
                    <ScrollViewer MaxHeight="360"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="GeneratedCliCommandText"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Skip breakdown overlay — floats above status bar, toggled by skip-count click -->
        <Border x:Name="SkipBreakdownOverlay"
                Grid.Row="4"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,8"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Canvas.ZIndex="100"
                Translation="0,0,32">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <TextBlock Text="{x:Bind ViewModel.SkipTooltip, Mode=OneWay}"
                       FontFamily="Consolas" FontSize="12"
                       IsTextSelectionEnabled="True" />
        </Border>

        <!-- Embedded terminal panel (ConPTY + xterm.js in WebView2) -->
        <Grid x:Name="TerminalHost" Grid.Row="5" Visibility="Collapsed" Background="#1E1E1E">
            <WebView2 x:Name="TerminalWebView" DefaultBackgroundColor="#1E1E1E" IsTabStop="True" />
        </Grid>

    </Grid>
</Window>
