# Build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
.vs/

# Publish
publish/
*.pubxml.user

# Tests / benchmarks
TestResults/
BenchmarkDotNet.Artifacts/
Yagu.Benchmarks/results/

# Local planning notes
PLANS/

# Rust build output
target/

# Settings written at runtime
%APPDATA%/Yagu/
*.log
PERFORMANCE_IMPROVEMENTS.md
PLAN.md
.analysis/
scripts/publish-to-azure.ps1
# Local-only Azure publish/deploy regression tests (publish script is local-only, never in CI)
Yagu.Tests/AzurePublishRegressionTests.local.cs
# Local-only telemetry config (real proxy URL + app token injected at build time; never committed)
Yagu/telemetry.local.props
# Generated telemetry config (carries the real endpoint + token; emitted under obj/ at build time)
**/TelemetryConfig.Configured.g.cs

# Installer staging (built by build-installer.ps1)
installer/staging/
installer/output/
# Cached WebView2 bootstrapper (downloaded by scripts/webview2-prereq.ps1)
installer/prerequisites/
# Vendored VC++ runtime redistributable (bundled locally for the installer)
vendor/vc-runtime/
!installer/*.exe
build_debug.txt
Yagu/Native/yagu_core.dll
build_output.txt
build_release.txt
build_out.txt
_SCRATCHPAD
preview-show-more-verification.txt
Yagu.Tests/tmp_coverage_rank.py
# Profiling scratch dumps emitted by scripts/parse-marks.py / etw-profile.ps1
scripts/marks-output*.txt

# Vendored OCR model weights / test data — NOT used by the build, ~365 MB of binaries.
# Yagu.OcrWorker references Sdcb.PaddleOCR.Models.Online (PaddleOCR models are lazy-downloaded
# to %LOCALAPPDATA%\Yagu at runtime) and the Tesseract wrapper (tessdata fetched at runtime),
# so the embedded PaddleOCR/PaddleNLP model weights and the Tesseract.Tests trained data are
# dead weight cloned from the upstream repos. The native Tesseract runtime DLLs (vendor/Tesseract
# x64/x86) are kept because they ship in the worker's output.
*.pdiparams
*.pdmodel
*.traineddata
