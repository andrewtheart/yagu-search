<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Yagu.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:Yagu.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="#805BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" Color="#B35BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPressed" Color="#FF5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedDisabled" Color="#336E7880" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUnchecked" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedPointerOver" Color="#1A5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedPressed" Color="#265BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedDisabled" Color="#0FFFFFFF" />

                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="#72D4FA" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" Color="#35A8D3" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedDisabled" Color="#3A5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#72D4FA" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#35A8D3" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedDisabled" Color="#3A5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#0B3141" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" Color="#0B3141" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPressed" Color="#062535" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedDisabled" Color="#665A6A72" />

                    <!-- INDETERMINATE is intentionally styled IDENTICALLY to UNCHECKED so a phantom
                         indeterminate visual state (WinUI can momentarily drop a two-state CheckBox into
                         it when its style/template is re-applied) can NEVER paint a "dash" glyph. No
                         CheckBox in this app uses three-state intentionally. Stroke/Fill mirror the
                         Unchecked brushes above; the glyph foreground is fully transparent. -->
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminate" Color="#805BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminatePointerOver" Color="#B35BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminatePressed" Color="#FF5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminateDisabled" Color="#336E7880" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminate" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminatePointerOver" Color="#1A5BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminatePressed" Color="#265BC9F5" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminateDisabled" Color="#0FFFFFFF" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminate" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminatePointerOver" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminatePressed" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminateDisabled" Color="#00000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="#80149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" Color="#B3149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPressed" Color="#FF149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedDisabled" Color="#337A8790" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUnchecked" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedPointerOver" Color="#1A149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedPressed" Color="#26149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedDisabled" Color="#0F000000" />

                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#1CAFE3" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="#32BDEB" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" Color="#118CB8" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedDisabled" Color="#3A149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#1CAFE3" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#32BDEB" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#118CB8" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedDisabled" Color="#3A149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#062635" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" Color="#062635" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPressed" Color="#041C28" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedDisabled" Color="#66627078" />

                    <!-- INDETERMINATE styled IDENTICALLY to UNCHECKED (see Default theme note). -->
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminate" Color="#80149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminatePointerOver" Color="#B3149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminatePressed" Color="#FF149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminateDisabled" Color="#337A8790" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminate" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminatePointerOver" Color="#1A149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminatePressed" Color="#26149DCE" />
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminateDisabled" Color="#0F000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminate" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminatePointerOver" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminatePressed" Color="#00000000" />
                    <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminateDisabled" Color="#00000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeUnchecked" ResourceKey="SystemColorButtonTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeUncheckedPressed" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeUncheckedDisabled" ResourceKey="SystemColorGrayTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillUnchecked" ResourceKey="SystemColorButtonFaceColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillUncheckedPointerOver" ResourceKey="SystemColorHighlightTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillUncheckedPressed" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillUncheckedDisabled" ResourceKey="SystemColorWindowColorBrush" />

                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeChecked" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" ResourceKey="SystemColorButtonTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" ResourceKey="SystemColorButtonFaceColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeCheckedDisabled" ResourceKey="SystemColorGrayTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillChecked" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" ResourceKey="SystemColorButtonTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedPressed" ResourceKey="SystemColorButtonFaceColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedDisabled" ResourceKey="SystemColorGrayTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundChecked" ResourceKey="SystemColorHighlightTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" ResourceKey="SystemColorButtonFaceColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundCheckedPressed" ResourceKey="SystemColorButtonTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundCheckedDisabled" ResourceKey="SystemColorWindowColorBrush" />

                    <!-- INDETERMINATE mapped to the UNCHECKED system colors; the glyph foreground is
                         mapped to the SAME brush as its box fill in every variant so the dash blends
                         invisibly into the box (see Default theme note). -->
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeIndeterminate" ResourceKey="SystemColorButtonTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeIndeterminatePointerOver" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeIndeterminatePressed" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeIndeterminateDisabled" ResourceKey="SystemColorGrayTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillIndeterminate" ResourceKey="SystemColorButtonFaceColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillIndeterminatePointerOver" ResourceKey="SystemColorHighlightTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillIndeterminatePressed" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckBackgroundFillIndeterminateDisabled" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundIndeterminate" ResourceKey="SystemColorButtonFaceColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundIndeterminatePointerOver" ResourceKey="SystemColorHighlightTextColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundIndeterminatePressed" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="CheckBoxCheckGlyphForegroundIndeterminateDisabled" ResourceKey="SystemColorWindowColorBrush" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Slightly wider scrollbar tracks and thumbs -->
            <x:Double x:Key="ScrollBarSize">14</x:Double>
            <x:Double x:Key="ScrollBarTrackBorderThemeThickness">1</x:Double>

            <Style TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <!-- Circular selection checkbox for the content-less selection boxes in the (virtualizing)
                 results list: the per-file-group header box and the toolbar "select all" box.

                 PERMANENT fix for the recurring phantom indeterminate "dash": a CheckBox in a
                 virtualizing ListView can transiently have its bool? IsChecked reset to null on
                 container recycle/template re-apply and drop into the Indeterminate visual state.
                 The stock template paints a dash there, and every prior mitigation (transparent
                 indeterminate theme brushes; a C# Indeterminate-event coercion) either lost the race
                 or did not reach the brush the stock template actually uses. This custom template has
                 NO dash element at all: the Indeterminate visual state is empty, so it renders
                 IDENTICALLY to Unchecked (an empty ring). A dash is therefore structurally impossible,
                 independent of IsChecked timing. Content-less by design (these boxes have no label). -->
            <Style x:Key="CircularSelectionCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="IsThreeState" Value="False" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid x:Name="RootGrid" Background="Transparent"
                                  Padding="{TemplateBinding Padding}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="HoverOverlay.Opacity" Value="1" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="HoverOverlay.Opacity" Value="1" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="Ring.Fill" Value="{ThemeResource CheckBoxCheckBackgroundFillChecked}" />
                                                <Setter Target="Ring.Stroke" Value="{ThemeResource CheckBoxCheckBackgroundStrokeChecked}" />
                                                <Setter Target="CheckGlyph.Opacity" Value="1" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked" />
                                        <!-- No setters: Indeterminate == Unchecked (empty ring, no glyph).
                                             This is what makes the phantom dash impossible. -->
                                        <VisualState x:Name="Indeterminate" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Grid Width="20" Height="20">
                                    <Ellipse x:Name="HoverOverlay" Width="20" Height="20" Opacity="0"
                                             Fill="{ThemeResource CheckBoxCheckBackgroundFillUncheckedPointerOver}" />
                                    <Ellipse x:Name="Ring" Width="20" Height="20" StrokeThickness="1"
                                             Fill="{ThemeResource CheckBoxCheckBackgroundFillUnchecked}"
                                             Stroke="{ThemeResource CheckBoxCheckBackgroundStrokeUnchecked}" />
                                    <FontIcon x:Name="CheckGlyph" Glyph="&#xE73E;" FontSize="12" Opacity="0"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{ThemeResource CheckBoxCheckGlyphForegroundChecked}" />
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Render placeholder / example hint text in italic across all text-entry fields.
                 The attached helper italicises only the PlaceholderTextContentPresenter, so the
                 user's typed text stays upright. -->
            <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
                <Setter Property="ui:PlaceholderTextStyler.Italic" Value="True" />
            </Style>
            <Style TargetType="AutoSuggestBox" BasedOn="{StaticResource DefaultAutoSuggestBoxStyle}">
                <Setter Property="ui:PlaceholderTextStyler.Italic" Value="True" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
