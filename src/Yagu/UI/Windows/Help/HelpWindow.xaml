<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Yagu.HelpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Yagu Help">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Title-bar-less window (no OS caption): Escape closes it, matching the top-right close button. -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnCloseAccelerator" />
        </Grid.KeyboardAccelerators>

        <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Top">
            <TextBlock Text="Yagu Help"
                       FontWeight="Bold"
                       FontSize="20"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="AppTitleText"
                       FontWeight="Bold"
                       FontSize="14"
                       TextWrapping="Wrap" />
            <TextBlock Text="Yet Another Grep Utility"
                       FontSize="13"
                       Opacity="0.65"
                       TextWrapping="Wrap" />
            <TextBlock Text="Work by Andrew Stein, 2026."
                       TextWrapping="Wrap" />
            <Border Height="1"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                    Margin="0,8,0,8" />
            <TextBlock Text="Keyboard shortcuts and usage details are shown in the help panel to the right."
                       FontSize="12"
                       Opacity="0.7"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="HelpPathText"
                       FontSize="11"
                       Opacity="0.55"
                       TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Border Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <WebView2 x:Name="HelpWebView"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

                <Grid x:Name="LoadingPanel"
                      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">
                        <ProgressRing IsActive="True"
                                      Width="32"
                                      Height="32" />
                        <TextBlock Text="Loading help..."
                                   Opacity="0.7" />
                    </StackPanel>
                </Grid>

                <ScrollViewer x:Name="FallbackPanel"
                              Visibility="Collapsed"
                              Padding="24"
                              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Help could not be rendered in WebView2"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="FallbackMessageText"
                                   TextWrapping="WrapWholeWords" />
                        <Border Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                Margin="0,8,0,8" />
                        <TextBlock x:Name="FallbackHelpText"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Title-bar-less close affordance: floats in the top-right corner (no OS caption strip). -->
        <Button x:Name="CloseButton"
                Grid.Column="1"
                Click="OnCloseClick"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="36"
                Height="32"
                MinWidth="0"
                Padding="0"
                Margin="0,-12,-12,0"
                Canvas.ZIndex="100"
                CornerRadius="4"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                ToolTipService.ToolTip="Close (Esc)">
            <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Button>
    </Grid>
</Window>
